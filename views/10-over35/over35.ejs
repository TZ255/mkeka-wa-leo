<!DOCTYPE html>
<html lang="sw">

<head>
  <%- include("../0-global/seo/head.ejs"); %>
  <link rel="stylesheet" href="/css/v7-mega.css">
  <link rel="stylesheet" href="/css/v1-global.css">
  <%- include('../0-global/google.ejs'); %>
</head>

<body>
  <%- include('../0-global/header.ejs'); %>
  <main>
    <section class="left">
      <h1 class="h2" style="font-size: 16px;">
        Mkeka wa Over/Under 3.5 - <%= SEO.trh.day %>, <%= SEO.trh.month_date %>
      </h1>
      <div class="introduction p">
        <p>
          Karibu kwenye mkusanyiko wa tabiri bora za <strong>Over/Under 3.5</strong> kwa mashabiki wa betting Tanzania!
          Hapa tunakuletea utabiri wa <strong>Over/Under 3.5</strong> kwa siku ya <strong>
            <%= SEO.trh.day %>, <%= SEO.trh.date %></strong>.
          Siku ya <%= SEO.siku.toLowerCase() %> tumekuletea jumla ya tabiri <strong><%= mikeka.length %></strong> za Over/Under 3.5, zikiwa zimechambuliwa kwa umakini na kwa kutumia data sahihi.
        </p>
        <p>
          Utabiri wa Over/Under 3.5 unamaanisha jumla ya magoli yote yaliyofungwa na timu zote mbili ndani ya mechi ni zaidi ya au chini ya 3.5.
          Ni aina ya beti inayopendwa sana kwa sababu inatoa odds nzuri na matokeo ya kuvutia, hasa kwenye ligi kubwa barani Ulaya na Afrika.
        </p>
        <ul style="list-style: circle;">
          <li><strong>Over 3.5:</strong> Jumla ya magoli ni zaidi ya 3.5 (manne au zaidi)</li>
          <li><strong>Under 3.5:</strong> Jumla ya magoli ni chini ya 3.5 (chini ya manne)</li>
        </ul>
      </div>

      <%- include('../0-global/banner.ejs'); %>
      <hr class="my-3 text-light">

      <%- include('./partials/mega.ejs'); %>
      <%- include('../0-global/weekday-nav.ejs'); %>
      <hr class="my-5 text-light">

      <%- include('../0-global/vip.ejs'); %>
      <%- include('../0-global/banner2.ejs'); %>
      <%- include('./partials/maana.ejs'); %>
      <%- include('./partials/ligi.ejs'); %>
      <%- include('../0-global/banner3.ejs'); %>
      <%- include('../0-global/somapia.ejs'); %>
    </section>

    <%- include('../0-global/right.ejs'); %>
  </main>


  <%- include('../0-global/footer.ejs'); %>

  <%- include('./partials/script.ejs'); %>
  <%- include('../0-global/script.ejs'); %>
  <%- include('../0-global/vip-modal.ejs'); %>

  <!-- bootstrap -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
