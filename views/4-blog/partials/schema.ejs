<!-- JSON-LD: Article -->
<%
const schemaCanonicalPath = meta.canonicalPath || (typeof seo !== 'undefined' && seo.canonicalPath) || (typeof page !== 'undefined' && page.canonicalPath);
if (!schemaCanonicalPath) {
  throw new Error('Article schema canonicalPath is required');
}
const schemaCanonicalUrl = `https://mkekawaleo.com${schemaCanonicalPath}`;
%>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": schemaCanonicalUrl
  },
  "url": schemaCanonicalUrl,
  "headline": meta.title,
  "description": meta.description,
  "image": meta.coverImage || 'https://mkekawaleo.com/favicon/android-chrome-512x512.png',
  "author": {
    "@type": "Person",
    "name": meta.author,
    "url": "https://mkekawaleo.com/about-us"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Mkeka wa Leo",
    "url": "https://mkekawaleo.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://mkekawaleo.com/favicon/android-chrome-192x192.png"
    }
  },
  "datePublished": meta.date_created,
  "dateModified": meta.date_modified,
  "articleSection": "Betting",
  "keywords": meta.keywords
}, null, 2) %>
</script>
