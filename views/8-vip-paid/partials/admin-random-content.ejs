<section id="admin-vip-random-content">
    <% if (typeof toastMessage !== 'undefined' && toastMessage) { %>
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 1080;">
            <div class="toast align-items-center text-bg-<%= toastMessage.type || 'success' %> border-0 vip-admin-toast" role="alert" aria-live="assertive" aria-atomic="true">
                <div class="d-flex">
                    <div class="toast-body">
                        <strong class="d-block"><%= toastMessage.title || 'VIP Admin' %></strong>
                        <span><%= toastMessage.body || '' %></span>
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>
    <% } %>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3 p-md-4">
            <div class="d-flex align-items-start justify-content-between flex-column flex-lg-row gap-3 mb-3">
                <div>
                    <span class="badge text-bg-dark mb-2">Admin VIP Generator</span>
                    <h1 class="h4 fw-bold mb-1">SUPER_STRONG Random VIP Betslips</h1>
                    <p class="text-secondary mb-0">Date: <strong><%= selectedDate %></strong> · Source tips: <strong><%= sourceCount %></strong></p>
                </div>
                <a class="btn btn-outline-dark" href="/mkeka/vip?date=<%= selectedDate %>">View VIP Page</a>
            </div>

            <% if (statusMessage) { %>
                <div class="alert alert-success py-2"><%= statusMessage %></div>
            <% } %>

            <form class="row g-2 align-items-end mb-3" method="get" action="<%= adminRoute %>">
                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold" for="vip-admin-date">Date</label>
                    <input type="date" class="form-control" name="date" value="<%= selectedDate %>" required id="vip-admin-date">
                </div>
                <div class="col-12 col-md-3 d-grid">
                    <button class="btn btn-dark fw-bold" type="submit">Load Date</button>
                </div>
                <div class="col-12 col-md-5">
                    <div class="alert alert-warning mb-0 py-2 small">
                        Generate saves directly to VIP database for this date. Existing VIP 1-4 tips for the date will be replaced.
                    </div>
                </div>
            </form>

            <div class="d-grid">
                <form hx-post="<%= adminRoute %>/generate"
                    hx-include="#vip-admin-date"
                    hx-target="#admin-vip-random-content"
                    hx-swap="outerHTML"
                    class="flex-fill">
                    <button class="btn btn-danger fw-bold w-100" type="submit">
                        Generate Random 12 And Save
                        <span class="spinner-border spinner-border-sm htmx-indicator ms-2" role="status" aria-hidden="true"></span>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <section id="vip-add-match" class="mb-4">
        <div class="accordion shadow-sm" id="vip-add-match-accordion">
            <div class="accordion-item border-0">
                <h2 class="accordion-header" id="vip-add-match-heading">
                    <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#vip-add-match-collapse" aria-expanded="false" aria-controls="vip-add-match-collapse">
                        <span class="badge text-bg-primary me-2">Add Match</span>
                        Add Match To VIP Betslip
                    </button>
                </h2>
                <div id="vip-add-match-collapse" class="accordion-collapse collapse" aria-labelledby="vip-add-match-heading" data-bs-parent="#vip-add-match-accordion">
                    <div class="accordion-body p-3 p-md-4">
                        <form class="row g-2 align-items-end"
                            hx-post="<%= adminRoute %>/add/lookup"
                            hx-target="#vip-add-match-details"
                            hx-swap="innerHTML">
                            <div class="col-12 col-md-8">
                                <label class="form-label fw-semibold" for="vip-add-fixture-id">Fixture ID</label>
                                <input type="number" class="form-control" name="fixture_id" id="vip-add-fixture-id" placeholder="Enter fixture_id" required>
                            </div>
                            <div class="col-12 col-md-4 d-grid">
                                <button class="btn btn-primary fw-semibold" type="submit">
                                    Fetch Fixture
                                    <span class="spinner-border spinner-border-sm htmx-indicator ms-2" role="status" aria-hidden="true"></span>
                                </button>
                            </div>
                        </form>

                        <div id="vip-add-match-details" class="mt-3"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="vip-saved-matches" class="pt-4 border-top border-4 border-dark-subtle">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-3 p-md-4">
                <span class="badge text-bg-dark mb-2">Saved VIP Matches</span>
                <h2 class="h5 fw-bold mb-1">Database Betslips for <%= selectedDate %></h2>
                <p class="text-secondary mb-0 small">These are already saved. Editing here updates the VIP database immediately.</p>
            </div>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3">
                        <div class="text-secondary small text-uppercase fw-semibold">Slips</div>
                        <div class="fs-4 fw-bold"><%= vipSummary.slipCount %></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3">
                        <div class="text-secondary small text-uppercase fw-semibold">Odds Sum</div>
                        <div class="fs-4 fw-bold"><%= vipSummary.totalOdds %></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3">
                        <div class="text-secondary small text-uppercase fw-semibold">Stake Each</div>
                        <div class="fs-4 fw-bold"><%= vipSummary.stake.toLocaleString('en-US') %></div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body p-3">
                        <div class="text-secondary small text-uppercase fw-semibold">Potential Win</div>
                        <div class="fs-4 fw-bold"><%= vipSummary.totalPotentialWin.toLocaleString('en-US') %></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
        <% vipSlips.forEach((slip) => { %>
            <div class="col-12">
                <article class="card border-0 shadow-sm overflow-hidden">
                    <div class="card-header text-bg-dark p-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                <div class="small text-white-50">Saved Betslip</div>
                                <h2 class="h5 fw-bold mb-0">VIP <%= slip.no %></h2>
                            </div>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge text-bg-light">Tips: <%= slip.tips.length %></span>
                                <span class="badge text-bg-warning">Odds: <%= slip.totalOdds %></span>
                                <span class="badge text-bg-success">Avg: <%= slip.averageAccuracy %>%</span>
                            </div>
                        </div>
                    </div>

                    <% if (!slip.tips.length) { %>
                        <div class="card-body p-4 text-center text-secondary">No tips saved for VIP <%= slip.no %>.</div>
                    <% } %>

                    <% slip.tips.forEach((tip) => { %>
                        <div class="card-body p-3 border-bottom border-3 border-dark-subtle">
                            <div class="d-flex justify-content-between flex-wrap gap-2 mb-3">
                                <div>
                                    <div class="fw-bold"><%= tip.time %> · <%= tip.match %></div>
                                    <div class="text-secondary small"><%= tip.league %> · Fixture <%= tip.fixture_id || '-' %></div>
                                </div>
                                <span class="badge <%= tip.status === 'won' ? 'text-bg-success' : (tip.status === 'lose' || tip.status === 'lost' ? 'text-bg-danger' : 'text-bg-secondary') %> align-self-start">
                                    <%= tip.status || 'pending' %> <%= tip.result || '-:-' %>
                                </span>
                            </div>

                            <form class="row g-2"
                                hx-post="<%= adminRoute %>/tip/<%= tip._id %>"
                                hx-target="#admin-vip-random-content"
                                hx-swap="outerHTML"
                                hx-indicator="#save-match-spinner-<%= tip._id %>">
                                <div class="col-6 col-md-2">
                                    <label class="form-label small">VIP</label>
                                    <input type="number" class="form-control form-control-sm" name="vip_no" min="1" max="4" value="<%= tip.vip_no %>">
                                </div>
                                <div class="col-6 col-md-2">
                                    <label class="form-label small">Date</label>
                                    <input type="date" class="form-control form-control-sm" name="date" value="<%= selectedDate %>">
                                </div>
                                <div class="col-6 col-md-2">
                                    <label class="form-label small">Time</label>
                                    <input type="time" class="form-control form-control-sm" name="time" value="<%= tip.time %>">
                                </div>
                                <div class="col-12 col-md-6">
                                    <label class="form-label small">League</label>
                                    <input type="text" class="form-control form-control-sm" name="league" value="<%= tip.league %>">
                                </div>
                                <div class="col-12 col-md-5">
                                    <label class="form-label small">Match</label>
                                    <input type="text" class="form-control form-control-sm" name="match" value="<%= tip.match %>">
                                </div>
                                <div class="col-12 col-md-3">
                                    <label class="form-label small">Pick</label>
                                    <input type="text" class="form-control form-control-sm" name="tip" value="<%= tip.tip %>">
                                </div>
                                <div class="col-4 col-md-1">
                                    <label class="form-label small">Odd</label>
                                    <input type="text" class="form-control form-control-sm" name="odd" value="<%= tip.odd %>">
                                </div>
                                <div class="col-4 col-md-1">
                                    <label class="form-label small">Status</label>
                                    <select class="form-select form-select-sm" name="status">
                                        <% ['pending', 'won', 'lose'].forEach((status) => { %>
                                            <option value="<%= status %>" <%= (tip.status || 'pending') === status ? 'selected' : '' %>><%= status %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-4 col-md-1">
                                    <label class="form-label small">Result</label>
                                    <input type="text" class="form-control form-control-sm" name="result" value="<%= tip.result || '-:-' %>">
                                </div>
                                <div class="col-12 align-self-end">
                                    <div class="d-grid d-lg-flex gap-2">
                                    <button class="btn btn-sm btn-primary fw-semibold flex-lg-fill" type="submit">
                                        Save Match
                                        <span id="save-match-spinner-<%= tip._id %>" class="spinner-border spinner-border-sm vip-action-spinner ms-2" role="status" aria-hidden="true"></span>
                                    </button>
                                    <button class="btn btn-sm btn-outline-dark fw-semibold flex-lg-fill" type="button"
                                        hx-post="<%= adminRoute %>/tip/<%= tip._id %>/copy-yh"
                                        hx-vals='{"date":"<%= selectedDate %>"}'
                                        hx-target="#admin-vip-random-content"
                                        hx-swap="outerHTML"
                                        hx-indicator="#copy-yh-spinner-<%= tip._id %>">
                                        Copy YH
                                        <span id="copy-yh-spinner-<%= tip._id %>" class="spinner-border spinner-border-sm vip-action-spinner ms-2" role="status" aria-hidden="true"></span>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger fw-semibold flex-lg-fill" type="button"
                                        hx-post="<%= adminRoute %>/tip/<%= tip._id %>/delete"
                                        hx-vals='{"date":"<%= selectedDate %>"}'
                                        hx-target="#admin-vip-random-content"
                                        hx-swap="outerHTML"
                                        hx-indicator="#delete-match-spinner-<%= tip._id %>"
                                        hx-confirm="Delete this match from VIP <%= tip.vip_no %>?">
                                        Delete
                                        <span id="delete-match-spinner-<%= tip._id %>" class="spinner-border spinner-border-sm vip-action-spinner ms-2" role="status" aria-hidden="true"></span>
                                    </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    <% }) %>

                    <div class="card-footer bg-light p-3">
                        <form class="row g-2 align-items-end"
                            hx-post="<%= adminRoute %>/booking"
                            hx-target="#admin-vip-random-content"
                            hx-swap="outerHTML">
                            <input type="hidden" name="date" value="<%= selectedDate %>">
                            <input type="hidden" name="slip_no" value="<%= slip.no %>">
                            <div class="col-12 col-md-5">
                                <label class="form-label small fw-semibold">Booking Code</label>
                                <input type="text" class="form-control" name="code" value="<%= slip.booking.code === '---' ? '' : slip.booking.code %>" placeholder="Booking code">
                            </div>
                            <div class="col-12 col-md-4">
                                <label class="form-label small fw-semibold">Company</label>
                                <select class="form-select" name="company">
                                    <% Object.keys(providers).forEach((company) => { %>
                                        <option value="<%= company %>" <%= slip.booking.company === company ? 'selected' : '' %>><%= providers[company].label %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-12 col-md-3 d-grid">
                                <button class="btn btn-dark fw-semibold" type="submit">
                                    Save Booking
                                    <span class="spinner-border spinner-border-sm htmx-indicator ms-2" role="status" aria-hidden="true"></span>
                                </button>
                            </div>
                        </form>
                    </div>
                </article>
            </div>
        <% }) %>
        </div>
    </section>
</section>
