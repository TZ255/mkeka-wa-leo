<style>
    .scratch-bar {
        position: relative;
        display: inline-block;
        cursor: not-allowed;
        user-select: none;
        padding: 4px 12px;
        min-width: 150px;
        text-align: center;
    }

    .scratch-bar::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background:
            repeating-linear-gradient(45deg,
                #a0a0a0,
                #a0a0a0 2px,
                #b8b8b8 2px,
                #b8b8b8 4px);
        border-radius: 3px;
        box-shadow:
            inset 0 1px 3px rgba(0, 0, 0, 0.3),
            0 1px 0 rgba(255, 255, 255, 0.5);
        pointer-events: none;
        z-index: 1;
    }

    .scratch-bar:hover::before {
        background:
            repeating-linear-gradient(45deg,
                #909090,
                #909090 2px,
                #a8a8a8 2px,
                #a8a8a8 4px);
    }

    /* Locked label with FontAwesome icon */
    .scratch-bar::after {
        content: '\f023  LOCKED';
        font-family: 'Font Awesome 6 Free', Arial, sans-serif;
        font-weight: 900;
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: #333;
        font-size: 11px;
        letter-spacing: 1px;
        text-shadow: 0 1px 0 rgba(255, 255, 255, 0.5);
        pointer-events: none;
        z-index: 2;
    }
</style>



