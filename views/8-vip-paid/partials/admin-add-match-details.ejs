<div class="border rounded bg-light p-3">
    <div class="alert alert-success py-2 small mb-3">
        Fixture found. Confirm the details, choose VIP No, add pick and odd.
    </div>

    <form class="row g-2"
        hx-post="<%= adminRoute %>/add"
        hx-target="#admin-vip-random-content"
        hx-swap="outerHTML">
        <div class="col-6 col-md-2">
            <label class="form-label small">Fixture ID</label>
            <input type="text" class="form-control form-control-sm" name="fixture_id" value="<%= fixture.fixture_id %>" readonly>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small">Date</label>
            <input type="date" class="form-control form-control-sm" name="date" value="<%= fixture.date %>" readonly>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small">Time</label>
            <input type="time" class="form-control form-control-sm" name="time" value="<%= fixture.time %>" readonly>
        </div>
        <div class="col-6 col-md-2">
            <label class="form-label small">VIP No</label>
            <input type="number" class="form-control form-control-sm" name="vip_no" min="1" max="4" value="1" required>
        </div>
        <div class="col-12 col-md-4">
            <label class="form-label small">League</label>
            <input type="text" class="form-control form-control-sm" name="league" value="<%= fixture.league %>" readonly>
            <input type="hidden" name="league_id" value="<%= fixture.league_id %>">
        </div>
        <div class="col-12 col-md-5">
            <label class="form-label small">Match</label>
            <input type="text" class="form-control form-control-sm" name="match" value="<%= fixture.match %>" readonly>
        </div>
        <div class="col-8 col-md-3">
            <label class="form-label small">Tip</label>
            <input type="text" class="form-control form-control-sm" name="tip" required>
        </div>
        <div class="col-4 col-md-2">
            <label class="form-label small">Odd</label>
            <input type="number" step="0.01" min="1" class="form-control form-control-sm" name="odd" required>
        </div>
        <div class="col-12 col-md-2 d-grid align-self-end">
            <button class="btn btn-sm btn-primary fw-semibold" type="submit">
                Add Match
                <span class="spinner-border spinner-border-sm htmx-indicator ms-2" role="status" aria-hidden="true"></span>
            </button>
        </div>
    </form>
</div>
