<div class="col-12 p-md-2" id="premium-list">
    <div class="mb-4 border-bottom border-light">
        <h3 class="fw-bold mb-0">
            <i class="fa-solid fa-crown text-warning me-2"></i>
            Tips za Nyongeza (Odds 3+)
        </h3>
        <p class="text-muted small mb-0 my-2 py-1 ps-2 pe-1 border-start border-secondary border-3">Ikiwa mtaji wako ni mdogo au unataka kuongeza wingi wa odds, tafadhali chagua mechi 2 au 3 zenye jumla ya odds 2.00 au zaidi kwenye tips hizi za nyongeza.</p>
    </div>
    <% if (betslip3 && betslip3.length > 0) { %>
    <div class="row g-3">
        <% betslip3.forEach(item => { %>
        <div class="col-12">
            <div class="card h-100 premium-tip-card">
                <div class="card-header border-0 py-3 premium-tip-card__header">
                    <div class="d-flex justify-content-between align-items-center text-white">
                        <span class="fw-semibold">
                            <i class="fa-solid fa-crown me-1"></i>
                            Bonus Tip
                        </span>
                        <small class="text-white-75">
                            <i class="fa-solid fa-calendar-check me-1"></i>
                            <%= new Date(item.date).toLocaleDateString('sw-TZ', { day: '2-digit', month: '2-digit', year: 'numeric' }) %>
                        </small>
                    </div>
                </div>
                <div class="card-body p-3 p-md-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="text-secondary">
                            <i class="fa-solid fa-clock me-1"></i>
                            <span class="fw-semibold text-dark"><%= item.time %></span>
                        </div>
                        <span
                            class="badge text-bg-light text-secondary fw-semibold"><%= item?.league %></span>
                    </div>
                    <h6 class="fw-bold text-dark mb-2"><%= item.match %></h6>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge bg-warning text-dark px-3 py-2" style="min-width: 120px;">
                            <i class="fa-solid fa-bullseye fa-beat me-1"></i>
                            <%= item.tip %>
                        </span>
                        <span class="fw-bold text-success <%= item?.status === "won" ? "d-inline-block" : "d-none" %>">
                            WON <%= item.result %>
                        </span>
                    </div>
                </div>
            </div>
        </div>
        <% }); %>
    </div>
    <% } %>

    <% if (!betslip3 || betslip3.length === 0) { %>
    <div class="text-center py-5">
        <div class="icon-circle-lg bg-light text-warning mx-auto mb-3">
            <i class="fa-solid fa-circle-info fa-2x"></i>
        </div>
        <h4 class="text-dark mb-2">Hakuna bonus tips zilizowekwa kwa siku hii.</h4>
        <p class="text-secondary mb-0">Tutakutumia mpya mara tu zinapoongezwa, endelea kufuatilia.</p>
    </div>
    <% } %>
</div>