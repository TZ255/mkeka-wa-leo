<section class="mvl-end">
  <div class="mvl-end__panel">
    <h2 class="mvl-end__title" <%- user.role === 'admin' ? 'onclick="adminUpdates()"' : '' %>>
      <i class="fa-solid fa-clipboard-check"></i>
      Muhtasari wa VIP
    </h2>

    <div class="mvl-end__grid">
      <div class="mvl-end__item">
        <span>VIP Slips</span>
        <strong><%= vipSummary.slipCount %></strong>
      </div>
      <div class="mvl-end__item">
        <span>Total Odds</span>
        <strong><%= vipSummary.totalOdds %></strong>
      </div>
      <div class="mvl-end__item">
        <span>Total Stake</span>
        <strong><%= vipSummary.totalStake.toLocaleString('en-US') %></strong>
      </div>
      <div class="mvl-end__item">
        <span>Possible Win</span>
        <strong><%= vipSummary.totalPotentialWin.toLocaleString('en-US') %></strong>
      </div>
    </div>

    <p class="mvl-end__note">Zingatia: Betting ni burudani. Beti kistaarabu na usibetie kiasi ambacho kikipotea kitakuathiri.</p>
  </div>
</section>

<script>
  function adminUpdates() {
    const adminSection = document.getElementById('adminSection');
    const prevSection = document.getElementById('prevSection');
    if (!adminSection || !prevSection) return;
    prevSection.classList.toggle('d-none');
    adminSection.classList.toggle('d-none');
  }
</script>
