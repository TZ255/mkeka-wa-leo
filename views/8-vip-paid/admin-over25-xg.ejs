<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Over 2.5 XG Tips</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.7/dist/htmx.min.js" integrity="sha384-ZBXiYtYQ6hJ2Y0ZNoYuI+Nq5MqWBr+chMrS/RkXpNzQCApHEhOt2aY8EJgqwHLkJ" crossorigin="anonymous"></script>
</head>

<body class="bg-light">
  <main class="container py-4 py-md-5">
    <div class="row justify-content-center">
      <div class="col-12 col-xl-11">
        <div class="card shadow-sm border-0">
          <div class="card-body p-3 p-md-4">
            <div class="d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3 mb-4">
              <div>
                <p class="text-uppercase text-secondary small fw-semibold mb-1">Admin Tool</p>
                <h1 class="h3 mb-2">Over/Under 2.5 Strong Tips</h1>
                <p class="text-secondary mb-0">Filter: <code>confidence in [SUPER_STRONG, STRONG]</code> and <code>meta.xG &gt;= 3.2</code>.</p>
              </div>
              <form action="<%= adminRoute %>" method="GET" class="row g-2 align-items-end">
                <div class="col-sm-auto">
                  <label for="date" class="form-label mb-1">Date</label>
                  <input id="date" name="date" type="date" class="form-control" value="<%= selectedDate || todayNairobi %>" required>
                </div>
                <div class="col-sm-auto">
                  <button type="submit" class="btn btn-dark w-100">Load tips</button>
                </div>
              </form>
            </div>

            <div class="d-flex flex-wrap gap-2 mb-4">
              <span class="badge text-bg-dark">Selected: <%= selectedDate || todayNairobi %></span>
              <span class="badge text-bg-primary">Tips: <%= stats.total %></span>
              <span class="badge text-bg-success">Odds found: <%= stats.withOdds %></span>
              <span class="badge text-bg-warning">Missing odds: <%= stats.missingOdds %></span>
            </div>

            <% if (errorMessage) { %>
              <div class="alert alert-danger" role="alert"><%= errorMessage %></div>
            <% } %>

            <% if (!errorMessage && tips.length === 0) { %>
              <div class="alert alert-secondary mb-0" role="alert">No qualifying tips found for <strong><%= selectedDate %></strong>.</div>
            <% } %>

            <% if (tips.length > 0) { %>
              <div class="row g-3">
                <% tips.forEach(function(tip) { %>
                  <div class="col-12 col-lg-6">
                    <div class="card h-100 border">
                      <div class="card-body">
                        <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-3">
                          <div>
                            <div class="d-flex flex-wrap gap-2 mb-2">
                              <span class="badge <%= tip.confidence === 'SUPER_STRONG' ? 'text-bg-success' : 'text-bg-primary' %>"><%= tip.confidence %></span>
                              <span class="badge text-bg-light border">xG: <%= tip.displayXg %></span>
                              <span class="badge text-bg-light border">Accuracy: <%= Number(tip.accuracy || 0).toFixed(1) %>%</span>
                              <span class="badge <%= tip.hasOdds ? 'text-bg-success' : 'text-bg-warning' %>"><%= tip.hasOdds ? 'Odds Ready' : 'Odds Missing' %></span>
                            </div>
                            <h2 class="h5 mb-1"><%= tip.match %></h2>
                            <p class="text-secondary mb-1"><%= tip.league %></p>
                            <p class="text-secondary small mb-0">Time: <strong><%= tip.time || '--:--' %></strong> | Fixture ID: <strong><%= tip.fixture_id || '--' %></strong></p>
                          </div>
                        </div>

                        <div class="table-responsive mb-3">
                          <table class="table table-sm align-middle mb-0">
                            <thead>
                              <tr>
                                <th scope="col">Market</th>
                                <th scope="col">Option A</th>
                                <th scope="col">Option B</th>
                                <th scope="col">Option C</th>
                              </tr>
                            </thead>
                            <tbody>
                              <tr>
                                <th scope="row">O/U 2.5</th>
                                <td>Over: <strong><%= tip.joinedOdds.over25 || '--' %></strong></td>
                                <td>Under: <strong><%= tip.joinedOdds.under25 || '--' %></strong></td>
                                <td></td>
                              </tr>
                              <tr>
                                <th scope="row">BTTS</th>
                                <td>Yes: <strong><%= tip.joinedOdds.bttsYes || '--' %></strong></td>
                                <td>No: <strong><%= tip.joinedOdds.bttsNo || '--' %></strong></td>
                                <td></td>
                              </tr>
                              <tr>
                                <th scope="row">1X2</th>
                                <td>1: <strong><%= tip.joinedOdds.home || '--' %></strong></td>
                                <td>X: <strong><%= tip.joinedOdds.draw || '--' %></strong></td>
                                <td>2: <strong><%= tip.joinedOdds.away || '--' %></strong></td>
                              </tr>
                            </tbody>
                          </table>
                        </div>

                        <form class="vip-selection-form">
                          <input type="hidden" name="tip_id" value="<%= String(tip._id) %>">

                          <div class="row g-3 mb-3">
                            <div class="col-md-8">
                              <label class="form-label">Bet / Tip</label>
                              <input
                                type="text"
                                name="tip"
                                class="form-control"
                                value="<%= tip.bet || '' %>"
                                required>
                            </div>
                            <div class="col-md-4">
                              <label class="form-label">Odd</label>
                              <input
                                type="text"
                                name="odd"
                                class="form-control"
                                value="<%= tip.selectedOdd || '' %>"
                                inputmode="decimal"
                                required>
                            </div>
                          </div>

                          <div class="row g-2">
                            <div class="col-sm-6 d-grid">
                              <button
                                type="button"
                                class="btn btn-outline-primary vip-action-btn"
                                data-default-text="Add to VIP 1"
                                hx-post="<%= adminRoute %>/add"
                                hx-include="closest form"
                                hx-vals='{"vip_no":"1"}'
                                hx-target="#save-feedback-<%= String(tip._id) %>"
                                hx-swap="innerHTML">
                                <span class="spinner-border spinner-border-sm me-2 d-none" aria-hidden="true"></span>
                                <span class="btn-label">Add to VIP 1</span>
                              </button>
                            </div>
                            <div class="col-sm-6 d-grid">
                              <button
                                type="button"
                                class="btn btn-outline-success vip-action-btn"
                                data-default-text="Add to VIP 2"
                                hx-post="<%= adminRoute %>/add"
                                hx-include="closest form"
                                hx-vals='{"vip_no":"2"}'
                                hx-target="#save-feedback-<%= String(tip._id) %>"
                                hx-swap="innerHTML">
                                <span class="spinner-border spinner-border-sm me-2 d-none" aria-hidden="true"></span>
                                <span class="btn-label">Add to VIP 2</span>
                              </button>
                            </div>
                          </div>
                        </form>

                        <div id="save-feedback-<%= String(tip._id) %>" class="mt-3"></div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    (function () {
      function getActionButton(evt) {
        return evt && evt.detail && evt.detail.elt && evt.detail.elt.closest('.vip-action-btn');
      }

      function setLoadingState(button, loading) {
        if (!button) return;
        const spinner = button.querySelector('.spinner-border');
        const label = button.querySelector('.btn-label');
        const defaultText = button.dataset.defaultText || 'Submit';

        button.disabled = loading;
        if (spinner) spinner.classList.toggle('d-none', !loading);
        if (label) label.textContent = loading ? 'Saving...' : defaultText;
      }

      document.body.addEventListener('htmx:beforeRequest', function (evt) {
        setLoadingState(getActionButton(evt), true);
      });

      document.body.addEventListener('htmx:afterRequest', function (evt) {
        setLoadingState(getActionButton(evt), false);
      });

      document.body.addEventListener('htmx:sendError', function (evt) {
        setLoadingState(getActionButton(evt), false);
      });

      document.body.addEventListener('htmx:responseError', function (evt) {
        setLoadingState(getActionButton(evt), false);
      });
    }());
  </script>
</body>

</html>
