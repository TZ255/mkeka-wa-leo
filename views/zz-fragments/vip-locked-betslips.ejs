<%
  const lockedSlips = typeof vipShowcaseSlips !== 'undefined'
    ? vipShowcaseSlips
    : (typeof vipSlips !== 'undefined' ? vipSlips : []);
  const lockedSummary = typeof vipShowcaseSummary !== 'undefined'
    ? vipShowcaseSummary
    : (typeof vipSummary !== 'undefined' ? vipSummary : { slipCount: 0, totalOdds: '0.00', stake: 15000, totalStake: 0, totalPotentialWin: 0 });
  const lockedCtaHref = typeof vipLockedCtaHref !== 'undefined' ? vipLockedCtaHref : '/mkeka/vip';
  const lockedResultDaysSource = typeof vipResultDays !== 'undefined' ? vipResultDays : [];
  const lockedResultDays = Array.isArray(lockedResultDaysSource)
    ? lockedResultDaysSource
    : [];
  const lockedResultGroups = lockedResultDays.length > 0 ? [lockedResultDays, lockedResultDays] : [];
%>

<style>
  .locked-vip-board {
    background: linear-gradient(180deg, #fffaf0 0%, #ffffff 62%);
    border: 1px solid #f4d17a;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 16px 34px rgba(120, 78, 12, .14);
  }

  .locked-vip-board__head {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, .88), rgba(255, 246, 214, .76)),
      linear-gradient(135deg, #f8d66d, #fff7d1 46%, #e5a91a);
    color: #241a05;
    padding: 18px 16px;
    border-bottom: 1px solid #e6bd55;
  }

  .locked-vip-headline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  .locked-vip-title {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .locked-vip-title-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #1c1917;
    color: #facc15;
    box-shadow: 0 8px 18px rgba(28, 25, 23, .18);
    flex: 0 0 auto;
  }

  .locked-vip-title h2 {
    color: #241a05;
  }

  .locked-vip-results {
    width: 100%;
    overflow: hidden;
    border-radius: 8px;
    border: 1px solid rgba(30, 41, 59, .14);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .94), rgba(248, 250, 252, .82)),
      #ffffff;
    padding: 6px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, .9), 0 10px 20px rgba(15, 23, 42, .08);
    mask-image: linear-gradient(90deg, transparent 0, #000 18px, #000 calc(100% - 18px), transparent 100%);
  }

  .locked-vip-results__track {
    display: flex;
    width: max-content;
    animation: lockedVipResultsScroll 30s linear infinite;
  }

  .locked-vip-results__group {
    display: flex;
    gap: 6px;
    padding-right: 6px;
  }

  .locked-vip-result-card {
    position: relative;
    width: 96px;
    min-height: 48px;
    flex: 0 0 auto;
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr) auto;
    grid-template-areas:
      "icon date date"
      "icon status status";
    align-items: center;
    column-gap: 6px;
    row-gap: 1px;
    border-radius: 8px;
    border: 1px solid rgba(15, 23, 42, .08);
    padding: 7px 8px 6px 11px;
    text-align: left;
    background: #ffffff;
    color: #111827;
    box-shadow: 0 6px 12px rgba(15, 23, 42, .08);
    overflow: hidden;
  }

  .locked-vip-result-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 4px;
    background: var(--vip-result-accent);
  }

  .locked-vip-result-card.is-won {
    --vip-result-accent: #16a34a;
    --vip-result-soft: rgba(22, 163, 74, .13);
    background: linear-gradient(180deg, #ffffff 0%, #f0fdf4 100%);
    border-color: #bbf7d0;
    color: #064e3b;
  }

  .locked-vip-result-card.is-lost {
    --vip-result-accent: #dc2626;
    --vip-result-soft: rgba(220, 38, 38, .13);
    background: linear-gradient(180deg, #ffffff 0%, #fff1f2 100%);
    border-color: #fecdd3;
    color: #7f1d1d;
  }

  .locked-vip-result-card.is-pending {
    --vip-result-accent: #64748b;
    --vip-result-soft: rgba(100, 116, 139, .14);
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    border-color: #cbd5e1;
    color: #334155;
  }

  .locked-vip-result-card i {
    grid-area: icon;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--vip-result-soft);
    color: var(--vip-result-accent);
    font-size: 13px;
    line-height: 1;
  }

  .locked-vip-result-card__date {
    grid-area: date;
    color: #111827;
    font-size: 12px;
    font-weight: 900;
    line-height: 1.05;
    white-space: nowrap;
  }

  .locked-vip-result-card__status {
    font-size: 9px;
    font-weight: 800;
    line-height: 1.05;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .locked-vip-result-card__status {
    grid-area: status;
    color: var(--vip-result-accent);
    letter-spacing: .02em;
  }

  @keyframes lockedVipResultsScroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  .locked-vip-board__head .vip-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #1c1917;
    color: #fde68a;
    border-radius: 999px;
    padding: 6px 11px;
    font-size: 12px;
    font-weight: 900;
    margin-bottom: 8px;
  }

  .locked-slip-card {
    border: 1px solid #f0d48a;
    border-radius: 8px;
    padding: 14px;
    height: 100%;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, .96), rgba(255, 250, 235, .96)),
      #ffffff;
    box-shadow: 0 10px 22px rgba(146, 100, 16, .08);
  }

  .locked-slip-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 12px;
  }

  .locked-slip-title strong {
    color: #241a05;
    font-size: 16px;
  }

  .locked-slip-chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border-radius: 999px;
    padding: 5px 9px;
    background: #fff3c4;
    color: #854d0e;
    border: 1px solid #f3cf75;
    font-size: 12px;
    font-weight: 900;
  }

  .locked-slip-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 12px;
  }

  .locked-slip-stat {
    background: #ffffff;
    border: 1px solid #f1dfb2;
    border-radius: 6px;
    padding: 9px;
    min-height: 62px;
  }

  .locked-slip-stat__label {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .locked-slip-stat span {
    color: #7c5a13;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: .03em;
    margin-bottom: 4px;
  }

  .locked-slip-stat i {
    color: #ca8a04;
    font-size: 12px;
  }

  .locked-slip-stat strong {
    color: #241a05;
    font-size: 16px;
    overflow-wrap: anywhere;
  }

  .locked-slip-stat.expired strong {
    color: #b91c1c;
  }

  .locked-slip-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    border: 0;
    border-radius: 6px;
    background: #1c1917;
    color: #fde68a;
    text-align: center;
    text-decoration: none;
    padding: 11px 12px;
    font-weight: 900;
    transition: background-color .2s ease, transform .2s ease;
    cursor: pointer;
  }

  .locked-slip-btn:hover {
    background: #3b2f16;
    color: #ffffff;
    transform: translateY(-1px);
  }

  .locked-summary {
    background: #fff8dc;
    border: 1px solid #f0d48a;
  }

  .locked-summary-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #854d0e;
    background: #fff3c4;
    border: 1px solid #f3cf75;
    margin-bottom: 5px;
  }

  @media (max-width: 575.98px) {
    .locked-vip-result-card {
      width: clamp(66px, calc((100vw - 76px) / 4), 78px);
      min-height: 46px;
      grid-template-columns: 20px minmax(0, 1fr);
      grid-template-areas:
        "icon date"
        "icon status";
      column-gap: 5px;
      padding: 7px 6px 6px 9px;
    }

    .locked-vip-result-card i {
      width: 20px;
      height: 20px;
      font-size: 11px;
    }

    .locked-vip-result-card__date {
      font-size: 11px;
    }

    .locked-vip-result-card__status {
      font-size: 8px;
    }
  }
</style>

<section class="locked-vip-board mx-auto">
  <div class="locked-vip-board__head">
    <span class="vip-badge"><i class="fa-solid fa-crown"></i> VIP BETSLIPS LOCKED</span>
    <div class="locked-vip-headline">
      <div class="locked-vip-title">
        <span class="locked-vip-title-icon"><i class="fa-solid fa-trophy"></i></span>
        <div>
          <h2 class="h4 fw-bold mb-1">Mikeka ya VIP</h2>
          <p class="mb-0" style="color:#6b4a0b;">Fungua VIP kuona mechi, tips na booking codes kamili.</p>
        </div>
      </div>
      <% if (lockedResultGroups.length > 0) { %>
        <div class="locked-vip-results" aria-label="VIP betslip results for the last <%= lockedResultDays.length %> days">
          <div class="locked-vip-results__track">
            <% lockedResultGroups.forEach((group, groupIndex) => { %>
              <div class="locked-vip-results__group" <%- groupIndex > 0 ? 'aria-hidden="true"' : '' %>>
                <% group.forEach((day) => { %>
                  <%
                    const dayStatus = ['won', 'lost'].includes(day.status) ? day.status : 'pending';
                    const statusLabel = dayStatus === 'won' ? 'Won' : (dayStatus === 'lost' ? 'Lost' : 'Pending');
                    const statusIcon = dayStatus === 'won' ? 'fa-circle-check' : (dayStatus === 'lost' ? 'fa-circle-xmark' : 'fa-clock');
                    const ariaText = `${day.weekday} ${day.label}: ${statusLabel}. ${day.winCount || 0} winning VIP betslips.`;
                  %>
                  <div class="locked-vip-result-card is-<%= dayStatus %>" aria-label="<%= ariaText %>">
                    <i class="fa-solid <%= statusIcon %>"></i>
                    <span class="locked-vip-result-card__date"><%= day.label %></span>
                    <span class="locked-vip-result-card__status"><%= statusLabel %></span>
                  </div>
                <% }) %>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="p-3 p-md-4">
    <% if (lockedSlips.length > 0 && lockedSlips.some((slip) => slip.tips.length > 0)) { %>
      <div class="row g-3">
        <% lockedSlips.forEach((slip) => { %>
          <% if (slip.tips.length > 0) { %>
            <div class="col-12 col-md-6">
              <article class="locked-slip-card">
                <div class="locked-slip-title">
                  <strong><i class="fa-solid fa-crown me-1" style="color:#ca8a04;"></i>VIP Betslip #<%= slip.no %></strong>
                  <span class="locked-slip-chip"><i class="fa-regular fa-futbol"></i><%= slip.tips.length %> Tips</span>
                </div>
                <div class="locked-slip-grid">
                  <div class="locked-slip-stat">
                    <span class="locked-slip-stat__label"><i class="fa-solid fa-chart-line"></i>Total Odds</span>
                    <strong><%= slip.totalOdds %></strong>
                  </div>
                  <div class="locked-slip-stat locked-slip-countdown <%= slip.countdown.expired ? 'expired' : '' %>"
                    data-ends-at="<%= slip.countdown.startsAt ? slip.countdown.startsAt.toISOString() : '' %>">
                    <span class="locked-slip-stat__label"><i class="fa-regular fa-clock"></i>Ends In</span>
                    <strong data-countdown-label><%= slip.countdown.label %></strong>
                  </div>
                  <div class="locked-slip-stat">
                    <span class="locked-slip-stat__label"><i class="fa-solid fa-ticket"></i>Booking Code</span>
                    <strong><%= slip.maskedBookingCode %></strong>
                  </div>
                  <div class="locked-slip-stat">
                    <span class="locked-slip-stat__label"><i class="fa-solid fa-coins"></i>Win @ <%= slip.stake.toLocaleString('en-US') %></span>
                    <strong><%= slip.potentialWin.toLocaleString('en-US') %></strong>
                  </div>
                </div>
                <% if (String(lockedCtaHref).startsWith('#')) { %>
                  <a class="locked-slip-btn" href="<%= lockedCtaHref %>"><i class="fa-solid fa-unlock-keyhole"></i> FUNGUA MKEKA</a>
                <% } else { %>
                  <button class="locked-slip-btn" type="button" onclick="window.location.href='<%= lockedCtaHref %>'"><i class="fa-solid fa-unlock-keyhole"></i> FUNGUA MKEKA</button>
                <% } %>
              </article>
            </div>
          <% } %>
        <% }) %>
      </div>

      <div class="locked-summary rounded-3 mt-3 p-3">
        <div class="row g-2 text-center">
          <div class="col-6 col-lg-3">
            <div class="locked-summary-icon"><i class="fa-solid fa-crown"></i></div>
            <div class="small text-secondary">Mikeka</div>
            <div class="fw-bold"><%= lockedSummary.slipCount %></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="locked-summary-icon"><i class="fa-solid fa-chart-simple"></i></div>
            <div class="small text-secondary">Total Odds</div>
            <div class="fw-bold"><%= lockedSummary.totalOdds %></div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="locked-summary-icon"><i class="fa-solid fa-money-bill-wave"></i></div>
            <div class="small text-secondary">Stake</div>
            <!-- <div class="fw-bold"><%= lockedSummary.totalStake.toLocaleString('en-US') %></div> -->
             <div class="fw-bold">30,000 TZS</div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="locked-summary-icon"><i class="fa-solid fa-sack-dollar"></i></div>
            <div class="small text-secondary">Possible Win</div>
            <div class="fw-bold text-success"><%= lockedSummary.totalPotentialWin.toLocaleString('en-US') %> TZS</div>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="alert alert-warning mb-0">Mikeka ya VIP bado haijawekwa kwa siku hii.</div>
    <% } %>
  </div>
</section>

<script>
  (() => {
    const countdowns = document.querySelectorAll('.locked-slip-countdown[data-ends-at]');
    if (!countdowns.length) return;

    const formatRemaining = (diffMs) => {
      if (diffMs <= 0) return 'Expired';

      const totalSeconds = Math.ceil(diffMs / 1000);
      const days = Math.floor(totalSeconds / 86400);
      const hours = Math.floor((totalSeconds % 86400) / 3600);
      const minutes = Math.floor((totalSeconds % 3600) / 60);
      const seconds = totalSeconds % 60;

      const parts = [];
      if (days) parts.push(`${days}d`);
      if (hours || days) parts.push(`${hours}h`);
      if (minutes || hours || days) parts.push(`${minutes}m`);
      parts.push(`${seconds}s`);
      return parts.join(' ');
    };

    const tick = () => {
      countdowns.forEach((node) => {
        const label = node.querySelector('[data-countdown-label]');
        const endsAt = node.dataset.endsAt;
        if (!label || !endsAt) return;

        const diff = new Date(endsAt).getTime() - Date.now();
        label.textContent = formatRemaining(diff);
        node.classList.toggle('expired', diff <= 0);
      });
    };

    tick();
    setInterval(tick, 1000);
  })();
</script>
