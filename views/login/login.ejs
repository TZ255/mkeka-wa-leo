<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%- include('../0-global/vip-styles.ejs'); %>
  <%- include('../0-global/fonts.ejs'); %>
  <%- include('./partials/style.ejs'); %>
  <title>Login VIP - Mkeka wa Leo</title>
</head>

<body>
  <div class="auth-shell d-flex justify-content-center align-items-center min-vh-100 px-3">
    <div class="login-form text-light h-auto rounded-4 p-4 p-md-5">
      <div class="text-center">
        <div class="auth-pill">VIP ACCESS</div>
        <div class="titleform fs-3 text-center mt-3 mb-4 fw-bold">Ingia / Jisajili <span class="hubColor">VIP</span></div>
        <p class="auth-subtitle mb-1">Karibu Mdau!</p>
        <p class="auth-subtitle mb-4">Tumia Google kuingia (haraka na salama)</p>
      </div>
      <%- include('../0-global/messages.ejs'); %>
      <div class="mt-2">
        <button class="google-btn w-100" id="login-button">
          <span class="google-icon"><i class="fa-brands fa-google" id="login-indicator"></i></span>
          &nbsp; Ingia kwa Google
        </button>
      </div>
      <div class="foot text-center mt-4">
        <p class="auth-note mb-0" style="font-size: 0.75rem;">Bonyeza button hapo juu kuingia moja kwa moja</p>
      </div>
    </div>
  </div>

  <!-- javascript code that will catch the onclick event of the google login button and add a fontawesome rotating class to the icon as well as disable the button to prevent multiple clicks: -->
  <script>
    document.getElementById('login-button').addEventListener('click', function() {
      var loginIndicator = document.getElementById('login-indicator');
      loginIndicator.classList.add('fa-spin');
      this.setAttribute('disabled', 'disabled');
      window.location.href = '/auth/google'; // Redirect to the Google authentication route
    });
  </script>
</body>
</html>
