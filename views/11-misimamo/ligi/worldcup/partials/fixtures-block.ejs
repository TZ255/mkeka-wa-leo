<section class="league-surface">
    <header class="league-surface-head">
        <h2 class="league-section-title"><%= title %></h2>
        <% if (subtitle) { %>
        <span class="league-chip"><%= subtitle %></span>
        <% } %>
    </header>

    <% if (!fixtures || fixtures.length === 0) { %>
    <div class="league-surface-body">
    <div class="league-empty">
        Kwa sasa sehemu hii bado haina mechi za kuonyesha. Ratiba na matokeo yatawekwa hapa pindi hatua husika itakapokuwa wazi.
    </div>
    </div>
    <% } else { %>
    <div class="league-surface-body">
    <div class="league-fixture-list">
        <% fixtures.forEach((fixture) => { %>
        <%- include('../../shared/partials/fixture-row.ejs', { fixture }) %>
        <% }) %>
    </div>
    </div>
    <% } %>
</section>
