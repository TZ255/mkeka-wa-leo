<section class="wc-section">
    <div class="wc-section-head">
        <h2 class="h3"><%= title %></h2>
        <span class="wc-round-chip"><%= players.length %> wachezaji</span>
    </div>

    <% if (!players || players.length === 0) { %>
    <div class="wc-empty">
        <p class="mb-1 fw-bold">Orodha ya vinara bado haijachukua sura kamili kwa sasa.</p>
        <p class="mb-0">Mashindano yakishika kasi, hapa ndipo majina ya wanaong'aa zaidi yatakapoanza kujipanga.</p>
    </div>
    <% } else { %>
    <div class="wc-table-wrap">
        <table class="wc-table" itemscope itemtype="https://schema.org/Table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Mchezaji</th>
                    <th>Timu</th>
                    <th class="text-center"><%= mode === 'assist' ? 'Asisti' : 'Magoli' %></th>
                    <th class="text-center"><%= mode === 'assist' ? 'Michezo' : 'Penati' %></th>
                </tr>
            </thead>
            <tbody>
                <% players.forEach((player, index) => { %>
                <tr>
                    <td class="text-center"><span class="wc-rank-badge"><%= index + 1 %></span></td>
                    <td><%= player.player.name %></td>
                    <td><%= player.statistics[0].team.name %></td>
                    <% if (mode === 'assist') { %>
                    <td class="text-center wc-highlight"><%= player.statistics[0].goals.assists ?? 0 %></td>
                    <td class="text-center"><%= player.statistics[0].games.appearences ?? '-' %></td>
                    <% } else { %>
                    <td class="text-center wc-highlight"><%= player.statistics[0].goals.total ?? 0 %></td>
                    <td class="text-center"><%= player.statistics[0].penalty?.scored ?? '-' %></td>
                    <% } %>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</section>
