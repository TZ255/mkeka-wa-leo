<!DOCTYPE html>
<html lang="sw">

<head>
    <%- include('../shared/partials/seo-head.ejs'); %>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../0-global/google.ejs'); %>
    <%- include('../shared/partials/theme.ejs'); %>
</head>

<body>
    <%- include('../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell wc-page text-align-justify">
            <%- include('./partials/hero.ejs', {
                partials,
                formattedUpdatedAt,
                hero: {
                    title: `Ratiba na matokeo ya Kombe la Dunia ${partials.season_long}`,
                    copy: 'Huu ndio ukurasa wa kufuatilia mechi zinazokuja, saa za kuanza, na matokeo ya Kombe la Dunia kuanzia hatua ya makundi hadi michezo ya mtoano.',
                }
            }) %>

            <%- include('./partials/nav.ejs', { partials }) %>

            <%- include('./partials/fixtures-block.ejs', {
                title: partials.current_round ? `Hatua inayopigiwa macho: ${partials.current_round}` : 'Mechi zilizo karibu zaidi',
                subtitle: `${currentRoundFixtures.length} mechi`,
                fixtures: currentRoundFixtures
            }) %>

            <% if (fixtureGroups.length > 0) { %>
            <% fixtureGroups.forEach((round) => { %>
            <%- include('./partials/fixtures-block.ejs', {
                title: round.round,
                subtitle: `${round.fixtures.length} mechi`,
                fixtures: round.fixtures
            }) %>
            <% }) %>
            <% } else { %>
            <section class="league-surface">
                <div class="league-surface-body">
                <div class="league-empty">
                    Ratiba ya mechi za Kombe la Dunia itaonekana hapa mara tu hatua inayofuata itakapopangwa wazi.
                </div>
                </div>
            </section>
            <% } %>

            <%- include('../../../0-global/somapia.ejs'); %>
        </section>
        <%- include('../../../0-global/right.ejs'); %>
    </main>

    <%- include('../../../0-global/footer.ejs'); %>
    <%- include('../../../0-global/modal-leon.ejs'); %>
    <%- include('../../../0-global/script.ejs'); %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
