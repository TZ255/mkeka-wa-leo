<!DOCTYPE html>
<html lang="sw">

<head>
    <%- include('../shared/partials/seo-head.ejs'); %>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../0-global/google.ejs'); %>
    <%- include('../shared/partials/theme.ejs'); %>
</head>

<body>
    <%- include('../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell wc-page text-align-justify">
            <%- include('./partials/hero.ejs', {
                partials,
                formattedUpdatedAt,
                hero: {
                    title: `Watoa assist bora wa Kombe la Dunia ${partials.season_long}`,
                    copy: 'Hapa unaona wabunifu wa mwisho wa mashindano, wale wanaofungua mabeki na kutoa pasi zinazogeuka kuwa magoli muhimu.',
                }
            }) %>

            <%- include('./partials/nav.ejs', { partials }) %>

            <% if (topAssists.length > 1) { %>
            <section class="league-surface">
                <div class="league-surface-body">
                <div class="league-grid-two">
                    <article class="league-highlight-card">
                        <h3 class="league-subsection-title">Kinara wa sasa</h3>
                        <p class="mb-1"><strong><%= topAssists[0].player.name %></strong></p>
                        <p class="mb-0"><%= topAssists[0].statistics[0].team.name %> anaongoza kwa <strong><%= topAssists[0].statistics[0].goals.assists ?? 0 %></strong> assists.</p>
                    </article>
                    <article class="league-highlight-card">
                        <h3 class="league-subsection-title">Anayemfukuzia</h3>
                        <p class="mb-1"><strong><%= topAssists[1].player.name %></strong></p>
                        <p class="mb-0"><%= topAssists[1].statistics[0].team.name %> anafukuzia kileleni akiwa na <strong><%= topAssists[1].statistics[0].goals.assists ?? 0 %></strong> assists.</p>
                    </article>
                </div>
                </div>
            </section>
            <% } %>

            <%- include('./partials/players-table.ejs', {
                title: `Orodha ya wachezaji wanaongoza kwa assists ${partials.league_name} ${partials.season_long}`,
                players: topAssists,
                mode: 'assist'
            }) %>

            <section class="league-surface">
                <div class="league-surface-body">
                <div class="league-cta-links">
                    <a href="/football/kombe-la-dunia">Rudi kwenye msimamo wa World Cup</a>
                    <a href="/football/kombe-la-dunia/ratiba">Angalia ratiba ya World Cup</a>
                    <a href="/football/kombe-la-dunia/wafungaji-bora">Angalia top scorers</a>
                </div>
                </div>
            </section>

            <%- include('../../../0-global/somapia.ejs'); %>
        </section>
    </main>

    <%- include('../../../0-global/footer.ejs'); %>
    <%- include('../../../0-global/modal-leon.ejs'); %>
    <%- include('../../../0-global/script.ejs'); %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
