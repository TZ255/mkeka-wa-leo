<!DOCTYPE html>
<html lang="sw">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Ratiba ya ligi kuu ya NBC Tanzania Bara <%= partials.season_long %>. Angalia ratiba ya msimu mzima wa ligi kuu ya NBC Tanzania bara, matokeo ya ligi kuu bara jana na leo">
    <%- include('../../../0-global/favicon.ejs') %>
    <meta property="article:published_time" content="<%= partials.createdAt %>">
    <meta property="article:modified_time" content="<%= partials.updatedAt %>">
    <link rel="canonical" href="https://mkekawaleo.com/football/fixtures/tanzania/premier-league">
    <title>Ratiba na Matokeo ya Ligi Kuu ya NBC Tanzania Bara <%= partials.season_short %></title>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../0-global/google.ejs'); %>
    <%- include('../../../0-global/fonts.ejs'); %>
    <%- include('../shared/partials/theme.ejs'); %>
    <style>
        .tdata {
            font-size: 12px;
        }
        
        .PST {
            text-decoration: line-through;
        }
    </style>
</head>

<body>
    <%- include('../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell text-align-justify">
            <% const navLinks = [
                { href: '/standings/football/tanzania/premier-league', label: 'Msimamo', icon: 'fa-solid fa-table', active: false },
                { href: '/football/fixtures/tanzania/premier-league', label: 'Ratiba na Matokeo', icon: 'fa-regular fa-calendar-days', active: true },
                { href: '/football/top-scorers/tanzania/premier-league', label: 'Wafungaji Bora', icon: 'fa-solid fa-futbol', active: false },
                { href: '/football/top-assists/tanzania/premier-league', label: 'Watoa Assist Bora', icon: 'fa-solid fa-handshake-angle', active: false }
            ]; %>

            <%- include('../shared/partials/hero.ejs', {
                partials,
                formattedUpdatedAt: new Date(partials.updatedAt).toLocaleString('sw-TZ', {
                    timeZone: 'Africa/Nairobi',
                    hour: '2-digit',
                    minute: '2-digit',
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                }),
                hero: {
                    title: `Ratiba na matokeo ya Ligi Kuu ya NBC Tanzania Bara ${partials.season_long}`,
                    copy: `Ukihitaji kujua mechi zilizopita, zinazofuata, na mwendo wa msimu mzima wa ${partials.league_name}, hapa ndipo unapata ratiba iliyopangwa kwa urahisi kufuatilia.`,
                    primary_pill: partials.season_long,
                    secondary_pill: partials.league_name,
                    stats: [
                        { value: partials.stats.fixtures || 0, label: 'Mechi' },
                        { value: partials.stats.rounds || 0, label: 'Hatua' },
                        { value: partials.stats.teams || 0, label: 'Timu' },
                    ],
                    meta_note: 'Ratiba ya msimu mzima wa ligi kuu Tanzania Bara',
                }
            }) %>

            <%- include('../shared/partials/nav.ejs', { links: navLinks }) %>

            <%- include('./partials/fixtures.ejs'); %>

            <div class="vidokezo">
                <h2 class="league-block-title">Vidokezo vya NBC <%= partials.season_short %></h2>
                <ul class="list-group list-group-flush fw-bold p-2">
                    <li class="list-group-item">
                        <a href="/standings/football/tanzania/premier-league">
                            Msimamo wa sasa wa Ligi Kuu ya NBC Tanzania Bara
                        </a>
                    </li>
                    <li class="list-group-item">
                        <a href="/football/top-scorers/tanzania/premier-league">
                            Wafungaji bora wa msimu wa ligi kuu Tanzania Bara
                        </a>
                    </li>
                    <li class="list-group-item">
                        <a href="/football/top-assists/tanzania/premier-league">
                            Watoa assist bora wa msimu wa ligi kuu Tanzania Bara
                        </a>
                    </li>
                </ul>
            </div>

            <div class="ratiba-timu">
                <h2 class="league-block-title">
                    Ratiba na matokeo kwa kila timu ya ligi kuu bara
                </h2>
                <p class="p">
                    Chagua timu unayotaka kufuatilia ili kuona mechi zake zote za nyumbani na ugenini pamoja na matokeo yake ndani ya msimu wa <%= partials.season_long %>.
                </p>
                <ul itemscope itemtype="https://schema.org/BreadcrumbList" class="list-group list-group-flush p-2">
                    <% standing.standing.forEach(team => { %>
                     <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="list-group-item">
                        <a itemprop="item" href="/football/fixtures/tanzania/premier-league/<%= team.team.id %>">
                            <span itemprop="name">
                                Ratiba na Matokeo ya Mechi za <%= team.team.name.replace('Kitayosce', 'Tabora United') %>
                            </span>
                        </a>
                        <meta itemprop="position" content="<%= team.rank %>">
                     </li>
                    <% }) %>
                </ul>
            </div>
            <%- include('../../../0-global/somapia.ejs'); %>
        </section>
        <%- include('../../../0-global/right.ejs'); %>
    </main>

    <%- include('../../../0-global/footer.ejs'); %>

    <%- include('../../../0-global/modal-leon.ejs'); %>
    <%- include('../../../0-global/script.ejs'); %>

    <!-- bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
