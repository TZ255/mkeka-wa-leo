<div class="faq" itemscope itemtype="https://schema.org/FAQPage">
    <h2 class="h2" itemprop="headline">Maswali Yalioulizwa Mara kwa Mara</h2>
    <div class="accordion" id="accordionPanelsStayOpenExample">
        <div class="accordion-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3 class="accordion-header" id="panelsStayOpen-headingOne">
                <button class="accordion-button fw-bold text-dark" type="button" data-bs-toggle="collapse"
                    data-bs-target="#panelsStayOpen-collapseOne" aria-expanded="true"
                    aria-controls="panelsStayOpen-collapseOne" itemprop="name">
                    <%= partials.team_info.team.name %> inashikilia nafasi ya ngapi?
                </button>
            </h3>
            <div id="panelsStayOpen-collapseOne" class="accordion-collapse collapse show"
                aria-labelledby="panelsStayOpen-headingOne">
                <div class="accordion-body" itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                    <p itemprop="text">
                        Hadi hivi sasa <%= partials.team_info.team.name %> inashikilia nafasi ya
                        <%= partials.team_info.rank %> katika msimamo wa ligi kuu Tanzania Bara <%= partials.season_long %>
                    </p>
                </div>
            </div>
        </div>
        <div class="accordion-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3 class="accordion-header" id="panelsStayOpen-headingTwo">
                <button class="accordion-button collapsed fw-bold text-dark" type="button" data-bs-toggle="collapse"
                    data-bs-target="#panelsStayOpen-collapseTwo" aria-expanded="false"
                    aria-controls="panelsStayOpen-collapseTwo" itemprop="name">
                    <%= partials.team_info.team.name %> ina points ngapi?
                </button>
            </h3>
            <div id="panelsStayOpen-collapseTwo" class="accordion-collapse collapse"
                aria-labelledby="panelsStayOpen-headingTwo">
                <div class="accordion-body" itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                    <p itemprop="text">
                        Hadi hivi sasa <%= partials.team_info.team.name %> ina jumla ya points
                        <%= partials.team_info.points %> na tofauti ya magoli <%= partials.team_info.goalsDiff %> ikiwa
                        imefunga magoli <%= partials.team_info.all.goals.for %> na kufungwa magoli
                        <%= partials.team_info.all.goals.against %>
                    </p>
                </div>
            </div>
        </div>
        <div class="accordion-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <h3 class="accordion-header" id="panelsStayOpen-headingThree">
                <button class="accordion-button collapsed fw-bold text-dark" type="button" data-bs-toggle="collapse"
                    data-bs-target="#panelsStayOpen-collapseThree" aria-expanded="false"
                    aria-controls="panelsStayOpen-collapseThree" itemprop="name">
                    <%= partials.team_info.team.name %> imeshinda mechi ngapi?
                </button>
            </h3>
            <div id="panelsStayOpen-collapseThree" class="accordion-collapse collapse"
                aria-labelledby="panelsStayOpen-headingThree">
                <div class="accordion-body" itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                    <p itemprop="text">
                        <%= partials.team_info.team.name %> imeshinda mechi <%= partials.team_info.all.played %>, imetoa
                        droo mechi <%= partials.team_info.all.draw %> na kufungwa <%= partials.team_info.all.lose %>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
<br><br><br>
<!-- Ratiba za Timu Nyingine -->
<div class="ratiba-timu">
    <div class="league-section-head">
        <div class="league-title-stack">
            <span class="league-overline">Timu Nyingine</span>
            <h2 class="h2 fs-5 mb-0">Ratiba na Matokeo ya Timu Zingine za Ligi Kuu Bara <%= partials.season_long %></h2>
            <p class="league-section-copy">Endelea na timu nyingine za ligi kuu kwa kuchagua klabu unayotaka kuona ratiba yake yote, matokeo na mechi zinazofuata.</p>
        </div>
        <span class="league-chip"><%= standing.length - 1 %> timu</span>
    </div>
    <ul itemscope itemtype="https://schema.org/BreadcrumbList" class="league-link-list p-0">
        <% standing.forEach(team => { %>
        <% if (team.team.id != partials.team_id) { %>
        <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a itemprop="item" href="/football/fixtures/tanzania/premier-league/<%= team.team.id %>">
                <span class="league-link-main">
                    <img class="league-link-logo" src="<%= team.team.logo %>" alt="<%= team.team.name.replace('Kitayosce', 'Tabora United') %>" loading="lazy">
                    <span class="league-link-copy">
                        <strong itemprop="name"><%= team.team.name.replace('Kitayosce', 'Tabora United') %></strong>
                        <span>Fungua ukurasa wa timu hii kuona mechi za nyumbani na ugenini, matokeo ya karibuni na safari yake ya msimu.</span>
                    </span>
                </span>
                <span class="league-link-arrow">
                    <i class="fa-solid fa-arrow-right"></i>
                </span>
            </a>
            <meta itemprop="position" content="<%= team.rank %>">
        </li>
        <% } %>
        <% }) %>
    </ul>
</div>
