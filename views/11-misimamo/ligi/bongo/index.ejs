<!DOCTYPE html>
<html lang="sw">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Msimamo wa ligi kuu ya NBC Tanzania Bara <%= partials.season_long %>. Angalia msimamo wa ligi kuu ya NBC Tanzania, ni Yanga ni Simba, nani anaongoza ligi kuu bara">
    <%- include('../../../0-global/favicon.ejs') %>
    <meta property="article:published_time" content="<%= partials.createdAt %>">
    <meta property="article:modified_time" content="<%= partials.updatedAt %>">
    <link rel="canonical" href="https://mkekawaleo.com/standings/football/tanzania/premier-league">
    <title>Msimamo wa Ligi Kuu ya NBC Tanzania Bara <%= partials.season_short %> - Nani Kinara, Nani Atashuka Daraja</title>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../0-global/google.ejs'); %>
    <%- include('../../../0-global/fonts.ejs'); %>
    <%- include('../shared/partials/theme.ejs'); %>
    <style>
        .tdata {
            font-size: 12px;
        }

        .champ1,
        .champ2 {
            background: green !important;
            color: white !important;
        }

        .champ3 {
            background: #1e90ff !important;
            color: white !important;
        }

        .champ13,
        .champ14 {
            background-color: #a52a2a !important;
            color: white !important;
        }

        .champ15,
        .champ16 {
            background-color: red !important;
            color: white !important;
        }

        .spanchamp {
            width: 20px !important;
            height: 20px !important;
            border-radius: 6px !important;
        }
    </style>

    <!-- JSON-LD Schema -->
     <%- include('./partials/json-standing.ejs'); %>
</head>

<body>
    <%- include('../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell text-align-justify">
            <% const navLinks = [
                { href: '/standings/football/tanzania/premier-league', label: 'Msimamo', icon: 'fa-solid fa-table', active: true },
                { href: '/football/fixtures/tanzania/premier-league', label: 'Ratiba na Matokeo', icon: 'fa-regular fa-calendar-days', active: false },
                { href: '/football/top-scorers/tanzania/premier-league', label: 'Wafungaji Bora', icon: 'fa-solid fa-futbol', active: false },
                { href: '/football/top-assists/tanzania/premier-league', label: 'Watoa Assist Bora', icon: 'fa-solid fa-handshake-angle', active: false }
            ]; %>

            <%- include('../shared/partials/hero.ejs', {
                partials,
                formattedUpdatedAt: new Date(partials.updatedAt).toLocaleString('sw-TZ', {
                    timeZone: 'Africa/Nairobi',
                    hour: '2-digit',
                    minute: '2-digit',
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                }),
                hero: {
                    title: `Msimamo wa Ligi Kuu ya NBC Tanzania Bara ${partials.season_long}`,
                    copy: `Fuatilia mbio za ubingwa, timu zinazopigania nafasi za juu, na zile zinazotafuta kujinasua mkiani mwa jedwali katika msimu wa ${partials.season_long}.`,
                    primary_pill: partials.season_long,
                    secondary_pill: partials.league_name,
                    stats: [
                        { value: partials.stats.teams || 0, label: 'Timu' },
                        { value: partials.stats.fixtures || 0, label: 'Mechi' },
                        { value: partials.stats.rounds || 0, label: 'Hatua' },
                    ],
                    meta_note: 'Takwimu za msimamo wa ligi kuu Tanzania Bara',
                }
            }) %>

            <%- include('../shared/partials/nav.ejs', { links: navLinks }) %>

            <%- include('./partials/standing.ejs'); %>

            <section class="league-surface">
                <header class="league-surface-head">
                    <div>
                        <div class="league-muted">Muhtasari wa ligi</div>
                        <h2 class="league-block-title mt-1">Msimu wa NBC <%= partials.season_short %> kwa ufupi</h2>
                    </div>
                </header>
                <div class="league-surface-body">
                    <%- include('./partials/intro-standing.ejs'); %>
                </div>
            </section>

            <div class="vidokezo">
                <h2 class="league-block-title">Angalia pia kurasa muhimu za NBC <%= partials.season_short %></h2>
                <ul class="list-group list-group-flush fw-bold p-2">
                    <li class="list-group-item">
                        <a href="/football/fixtures/tanzania/premier-league">
                            Ratiba na matokeo ya mechi zote za ligi kuu Tanzania Bara
                        </a>
                    </li>
                    <li class="list-group-item">
                        <a href="/football/top-scorers/tanzania/premier-league">
                            Wafungaji bora ligi kuu Tanzania Bara
                        </a>
                    </li>
                    <li class="list-group-item">
                        <a href="/football/top-assists/tanzania/premier-league">
                            Watoa assist bora ligi kuu Tanzania Bara
                        </a>
                    </li>
                </ul>
            </div>

            <%- include('./partials/faqpage.ejs'); %>
            <%- include('../../../0-global/somapia.ejs'); %>
        </section>
        <%- include('../../../0-global/right.ejs'); %>
    </main>

    <%- include('../../../0-global/footer.ejs'); %>

    <%- include('../../../0-global/modal-leon.ejs'); %>
    <%- include('../../../0-global/script.ejs'); %>

    <!-- bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
