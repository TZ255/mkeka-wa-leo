<!DOCTYPE html>
<html lang="sw">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Angalia orodha ya wachezaji wanaongoza kwa asisti NBC - Ligi Kuu Tanzania Bara kwa msimu wa <%= partials.season_long %>. Hawa hapa vinara wa Assist NBC.">
    <meta property="article:modified_time" content="<%= partials.updatedAt %>">
    <link rel="canonical" href="https://mkekawaleo.com<%= partials.canonical_path %>">
    <%- include('../../../../0-global/favicon.ejs') %>
    <title>Watoa Assist Bora NBC <%= partials.season_long %> - Vinara wa Assist Ligi Kuu Tanzania Bara</title>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../../0-global/google.ejs'); %>
    <%- include('../../../../0-global/fonts.ejs'); %>
    <%- include('../../shared/partials/theme.ejs'); %>
    <%- include('./partials/schema.ejs'); %>
</head>

<body>
    <%- include('../../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell text-align-justify">
            <% const navLinks = [
                { href: '/standings/football/tanzania/premier-league', label: 'Msimamo', icon: 'fa-solid fa-table', active: false },
                { href: '/football/fixtures/tanzania/premier-league', label: 'Ratiba na Matokeo', icon: 'fa-regular fa-calendar-days', active: false },
                { href: '/football/top-scorers/tanzania/premier-league', label: 'Wafungaji Bora', icon: 'fa-solid fa-futbol', active: false },
                { href: '/football/top-assists/tanzania/premier-league', label: 'Watoa Assist Bora', icon: 'fa-solid fa-handshake-angle', active: true }
            ]; %>

            <%- include('../../shared/partials/hero.ejs', {
                partials,
                formattedUpdatedAt: new Date(partials.updatedAt).toLocaleString('en-US', {
                    timeZone: 'Africa/Nairobi',
                    hour: '2-digit',
                    minute: '2-digit',
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                }),
                hero: {
                    title: `Watoa Assist Bora wa NBC ${partials.season_long}`,
                    copy: `Ukurasa huu unaonyesha wabunifu wakubwa wa Ligi Kuu Tanzania Bara, wale wanaotengeneza nafasi na pasi za mwisho zinazobadilika kuwa magoli.`,
                    primary_pill: partials.season_long,
                    secondary_pill: partials.ligi,
                    stats: [
                        { value: partials.stats.assist || 0, label: 'Wachezaji' },
                        { value: partials.stats.teams || 0, label: 'Timu' },
                        { value: partials.stats.fixtures || 0, label: 'Mechi' },
                    ],
                }
            }) %>

            <%- include('../../shared/partials/nav.ejs', { links: navLinks }) %>

            <% if (top_assists?.length > 1) { %>
            <div class="league-grid-two">
                <article class="league-highlight-card">
                    <h2 class="h5">Kinara wa sasa</h2>
                    <p class="mb-1"><strong><%= top_assists[0].playerName %></strong></p>
                    <p class="mb-0"><%= top_assists[0].club %> anaongoza akiwa na <strong><%= top_assists[0].assists %></strong> assists.</p>
                </article>
                <article class="league-highlight-card">
                    <h2 class="h5">Anayemfukuzia</h2>
                    <p class="mb-1"><strong><%= top_assists[1].playerName %></strong></p>
                    <p class="mb-0"><%= top_assists[1].club %> yupo karibu kileleni akiwa na <strong><%= top_assists[1].assists %></strong> assists.</p>
                </article>
            </div>
            <% } %>

            <div class="table-section" itemscope itemtype="https://schema.org/Table">
                <div class="league-section-head">
                    <div class="league-title-stack">
                        <span class="league-overline">Watoa Assist Bora</span>
                        <h2 class="h2 fs-5 mb-0" itemprop="about">Wachezaji Wanaongoza kwa Assist NBC <%= partials.season_short %></h2>
                        <p class="league-section-copy">Hii ni jedwali ya wabunifu wa NBC wanaotengeneza pasi za mwisho, klabu wanazotokea na kiwango chao cha ubunifu msimu huu.</p>
                    </div>
                    <span class="league-chip"><%= top_assists.length %> wachezaji</span>
                </div>
                <div class="league-table-wrap">
                    <table class="league-table league-player-table">
                        <colgroup>
                            <col class="rank-col">
                            <col class="player-col">
                            <col class="team-col">
                            <col class="meta-col">
                            <col class="stat-col">
                        </colgroup>
                        <thead>
                            <tr>
                                <th class="rank-cell text-center">#</th>
                                <th class="team-cell">Mchezaji</th>
                                <th>Timu</th>
                                <th>Utaifa</th>
                                <th class="text-center">Assist</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% top_assists.forEach((player, index) => { %>
                            <tr>
                                <td class="rank-cell rank-badge-cell">
                                    <span class="league-rank-wrap">
                                        <span class="league-rank-marker"></span>
                                        <span class="league-rank-number"><%= index + 1 %></span>
                                    </span>
                                </td>
                                <td class="team-cell">
                                    <div class="league-player-cell">
                                        <div>
                                            <strong><%= player.playerName %></strong>
                                        </div>
                                    </div>
                                </td>
                                <td><%= player.club %></td>
                                <td><%= player.country %></td>
                                <td class="text-center league-highlight"><%= player.assists %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="league-legend">
                    <span><a href="/football/top-scorers/tanzania/premier-league">Wafungaji Bora wa NBC <%= partials.season_short %></a></span>
                    <span><a href="/standings/football/tanzania/premier-league">Msimamo wa Ligi Kuu Tanzania Bara <%= partials.season_short %></a></span>
                    <span><a href="/football/fixtures/tanzania/premier-league">Ratiba na matokeo ya NBC <%= partials.season_short %></a></span>
                </div>
            </div>

            <%- include('../../../../0-global/somapia.ejs'); %>
        </section>
    </main>

    <%- include('../../../../0-global/footer.ejs'); %>
    <%- include('../../../../0-global/script.ejs'); %>
    <%- include('../../../../0-global/modal-leon.ejs'); %>

    <!-- bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
