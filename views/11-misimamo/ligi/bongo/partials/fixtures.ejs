<div class="ratiba-section">
  <!-- recent results -->
  <% if (recent_results.length> 0) { %>
  <div class="rounds-table" itemscope itemtype="https://schema.org/Table">
    <div class="league-section-head">
      <div class="league-title-stack">
        <span class="league-overline">Matokeo ya Karibuni</span>
        <h2 class="h2 fs-5 mb-0" itemprop="about">Matokeo ya Hivi Karibuni ya Ligi Kuu NBC <%= partials.season_short %></h2>
        <p class="league-section-copy">Haya ni matokeo ya mechi zilizomalizika karibuni zaidi, yakionyesha waliotawala mchezo na mabadiliko ya mwisho wa wiki ya ligi.</p>
      </div>
      <span class="league-chip"><%= recent_results.length %> mechi</span>
    </div>
    <div class="league-fixture-list">
      <% recent_results.forEach(fixture=> { %>
      <%
        const statusShort = fixture?.fixture?.status?.short;
        const homeGoals = fixture?.goals?.home;
        const awayGoals = fixture?.goals?.away;
        const isCompleted = ['FT', 'AET', 'PEN', 'AWD', 'WO'].includes(statusShort);
        const isDraw = homeGoals !== null && awayGoals !== null && homeGoals === awayGoals;
        const homeWinner = isCompleted && !isDraw && fixture?.teams?.home?.winner === true;
        const awayWinner = isCompleted && !isDraw && fixture?.teams?.away?.winner === true;
      %>
      <article class="league-fixture-card league-fixture-card-detail">
        <div class="league-fixture-time">
          <strong class="d-block"><%= new Date(fixture.fixture.date).toLocaleDateString('en-GB', {timeZone: 'Africa/Nairobi' }) %></strong>
          <span><%= new Date(fixture.fixture.date).toLocaleTimeString('en-US', {timeZone: 'Africa/Nairobi' , hour12:false, hour: "2-digit" , minute: "2-digit" }) %></span>
        </div>
        <div class="league-fixture-teams">
          <span class="league-fixture-team-row">
            <img class="league-fixture-team-logo" src="<%= fixture.teams.home.logo %>" alt="<%= fixture.teams.home.name.replace('Kitayosce', 'Tabora United' ) %>" loading="lazy">
            <span class="league-fixture-team <%= homeWinner ? 'is-winner' : '' %>"><%= fixture.teams.home.name.replace('Kitayosce', 'Tabora United' ) %></span>
          </span>
          <span class="league-fixture-team-row">
            <img class="league-fixture-team-logo" src="<%= fixture.teams.away.logo %>" alt="<%= fixture.teams.away.name.replace('Kitayosce', 'Tabora United' ) %>" loading="lazy">
            <span class="league-fixture-team <%= awayWinner ? 'is-winner' : '' %>"><%= fixture.teams.away.name.replace('Kitayosce', 'Tabora United' ) %></span>
          </span>
        </div>
        <div class="league-fixture-score">
          <span class="d-block"><%= fixture.goals.home ?? '-' %></span>
          <span class="d-block"><%= fixture.goals.away ?? '-' %></span>
          <span class="league-fixture-status d-block"><%= fixture.fixture.status.short %></span>
        </div>
        <% if (fixture.fixture.venue?.name) { %>
        <div class="league-fixture-venue"><%= fixture.fixture.venue.name %></div>
        <% } %>
      </article>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- recent fixtures -->
  <div class="rounds-table my-5" itemscope itemtype="https://schema.org/Table">
    <div class="league-section-head">
      <div class="league-title-stack">
        <span class="league-overline">Mechi Zijazo</span>
        <h2 class="h2 fs-5 mb-0" itemprop="about">Mechi Zijazo za Ligi Kuu NBC <%= partials.season_short %></h2>
        <p class="league-section-copy">Pata ratiba ya mechi zinazofuata, muda wa kuanza, uwanja wa mchezo na pambano linalokusubiri kwenye duru inayofuata.</p>
      </div>
      <span class="league-chip"><%= recent_fixtures.length %> mechi</span>
    </div>
    <div class="league-fixture-list">
      <% recent_fixtures.forEach(fixture=> { %>
      <article class="league-fixture-card league-fixture-card-detail">
        <div class="league-fixture-time">
          <strong class="d-block"><%= new Date(fixture.fixture.date).toLocaleDateString('en-GB', {timeZone: 'Africa/Nairobi' }) %></strong>
          <span><%= new Date(fixture.fixture.date).toLocaleTimeString('en-US', {timeZone: 'Africa/Nairobi' , hour12:false, hour: "2-digit" , minute: "2-digit" }) %></span>
        </div>
        <div class="league-fixture-teams">
          <span class="league-fixture-team-row">
            <img class="league-fixture-team-logo" src="<%= fixture.teams.home.logo %>" alt="<%= fixture.teams.home.name.replace('Kitayosce', 'Tabora United' ) %>" loading="lazy">
            <span class="league-fixture-team"><%= fixture.teams.home.name.replace('Kitayosce', 'Tabora United' ) %></span>
          </span>
          <span class="league-fixture-team-row">
            <img class="league-fixture-team-logo" src="<%= fixture.teams.away.logo %>" alt="<%= fixture.teams.away.name.replace('Kitayosce', 'Tabora United' ) %>" loading="lazy">
            <span class="league-fixture-team"><%= fixture.teams.away.name.replace('Kitayosce', 'Tabora United' ) %></span>
          </span>
        </div>
        <div class="league-fixture-score">
          <span class="d-block"><%= fixture.goals.home ?? '-' %></span>
          <span class="d-block"><%= fixture.goals.away ?? '-' %></span>
          <span class="league-fixture-status d-block"><%= fixture.fixture.status.short %></span>
        </div>
        <% if (fixture.fixture.venue?.name) { %>
        <div class="league-fixture-venue"><%= fixture.fixture.venue.name %></div>
        <% } %>
      </article>
      <% }) %>
    </div>
  </div>

  <!-- All fixtures -->
  <div class="rounds-table my-5">
    <div class="league-section-head">
      <div class="league-title-stack">
        <span class="league-overline">Msimu Mzima</span>
        <h2 class="h2 fs-5 mb-0">Ratiba na Matokeo ya Msimu Mzima wa <%= partials.season_long %></h2>
        <p class="league-section-copy">Angalia safari yote ya NBC kuanzia mechi za mwanzo wa msimu hadi raundi za mwisho, ukifuatilia siku kwa siku jinsi ligi ilivyochezwa.</p>
      </div>
      <span class="league-chip"><%= agg.length %> siku</span>
    </div>
    <p class="p">
      Katika msimu wa NBC <%= partials.season_long %>, jumla ya mechi <%= standing.season_fixtures?.length %> zinahusisha vilabu <%= standing.standing?.length %> vinavyocheza nyumbani na ugenini katika safari nzima ya ligi.
    </p>
    <% agg.forEach(round=> { %>
    <div class="rounds-table" itemscope itemtype="https://schema.org/Table">
      <meta itemprop="about" content="Ratiba na Matokeo ya NBC Tanzania Bara - Msimu Mzima wa <%= partials.season_long %>">
      <div class="league-section-head">
        <h3 class="h3 fs-6 mb-0">
          <%= new Intl.DateTimeFormat('sw-TZ', { weekday: 'long' , day: '2-digit' , month: 'short' , year: 'numeric' }).format(new Date(round.round)) %>
        </h3>
        <span class="league-chip"><%= round.fixtures.length %> mechi</span>
      </div>
      <div class="league-fixture-list">
        <% round.fixtures.forEach(fixture=> { %>
        <%
          const statusShort = fixture?.fixture?.status?.short;
          const homeGoals = fixture?.goals?.home;
          const awayGoals = fixture?.goals?.away;
          const isCompleted = ['FT', 'AET', 'PEN', 'AWD', 'WO'].includes(statusShort);
          const isDraw = homeGoals !== null && awayGoals !== null && homeGoals === awayGoals;
          const homeWinner = isCompleted && !isDraw && fixture?.teams?.home?.winner === true;
          const awayWinner = isCompleted && !isDraw && fixture?.teams?.away?.winner === true;
        %>
        <article class="league-fixture-card league-fixture-card-detail" itemscope itemtype="https://schema.org/SportsEvent">
          <div class="league-fixture-time">
            <strong class="d-block"><%= new Date(fixture.fixture.date).toLocaleDateString('en-GB', {timeZone: 'Africa/Nairobi' }) %></strong>
            <span><%= new Date(fixture.fixture.date).toLocaleTimeString('en-US', {timeZone: 'Africa/Nairobi' , hour12:false, hour: "2-digit" , minute: "2-digit" }) %></span>
            <meta itemprop="startDate" content="<%= fixture.fixture.date %>">
            <meta itemprop="endDate" content="<%= new Date((fixture.fixture.timestamp + 5*60*60) * 1000).toISOString().slice(0,19) + '+03:00' %>">
            <meta itemprop="location" content="<%= fixture.fixture?.venue?.name %>, <%= fixture.fixture?.venue?.city %>, <%= fixture.league.country %>">
          </div>
          <div class="league-fixture-teams">
            <span class="league-fixture-team-row">
              <img class="league-fixture-team-logo" src="<%= fixture.teams.home.logo %>" alt="<%= fixture.teams.home.name.replace('Kitayosce', 'Tabora United' ) %>" loading="lazy">
              <span class="league-fixture-team <%= homeWinner ? 'is-winner' : '' %>">
                <%= fixture.teams.home.name.replace('Kitayosce', 'Tabora United' ) %>
              </span>
            </span>
            <span class="league-fixture-team-row">
              <img class="league-fixture-team-logo" src="<%= fixture.teams.away.logo %>" alt="<%= fixture.teams.away.name.replace('Kitayosce', 'Tabora United' ) %>" loading="lazy">
              <span class="league-fixture-team <%= awayWinner ? 'is-winner' : '' %>">
                <%= fixture.teams.away.name.replace('Kitayosce', 'Tabora United' ) %>
              </span>
            </span>
            <meta itemprop="description" content="<%= fixture.league.name %> mechi kati ya <%= fixture.teams.home.name %> na <%= fixture.teams.away.name %>.">
            <meta itemprop="name" content="<%= fixture.teams.home.name %> vs <%= fixture.teams.away.name %>">
            <meta itemprop="performer" content="<%= fixture.teams.home.name %>">
            <meta itemprop="performer" content="<%= fixture.teams.away.name %>">
          </div>
          <div class="league-fixture-score">
            <span class="d-block"><%= fixture.goals.home ?? '-' %></span>
            <span class="d-block"><%= fixture.goals.away ?? '-' %></span>
            <span class="league-fixture-status d-block"><%= fixture.fixture.status.short %></span>
          </div>
          <% if (fixture.fixture.venue?.name) { %>
          <div class="league-fixture-venue"><%= fixture.fixture.venue.name %></div>
          <% } %>
        </article>
        <% }) %>
      </div>
    </div>
    <% }) %>
  </div>
</div>
