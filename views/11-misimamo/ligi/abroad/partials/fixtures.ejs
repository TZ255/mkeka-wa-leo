<div class="ratiba-section" itemscope>
    <section class="league-surface">
        <header class="league-surface-head">
            <div class="league-title-stack">
                <span class="league-overline">Ratiba na Matokeo</span>
                <h2 class="league-section-title">Ratiba na Matokeo ya <%= partials.league_name %> <%= partials.season_long %></h2>
                <p class="league-section-copy">Fuata mechi zilizochezwa, mechi zijazo na mwenendo wa kila raundi ya <%= partials.ligi %> katika msimu huu.</p>
            </div>
            <span class="league-chip"><%= partials.stats?.fixtures || 0 %> mechi</span>
        </header>
    </section>

    <% if (typeof standing.standing[0] === 'object' && standing.standing[0] !== null && !Array.isArray(standing.standing[0]) && standing.current_round_fixtures?.length > 0) { %>
    <section class="league-surface" itemscope itemtype="https://schema.org/Table">
        <header class="league-surface-head">
            <h3 class="league-subsection-title" itemprop="about"><%= standing.current_round_fixtures[0]?.league?.round %></h3>
            <span class="league-chip"><%= standing.current_round_fixtures.length %> mechi</span>
        </header>
        <div class="league-surface-body">
            <div class="league-fixture-list">
                <% standing.current_round_fixtures.forEach(fixture => { %>
                <%- include('../../shared/partials/fixture-row.ejs', { fixture }) %>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <% agg.forEach(round => { %>
    <section class="league-surface" itemscope itemtype="https://schema.org/Table">
        <header class="league-surface-head">
            <h3 class="league-subsection-title" itemprop="about"><%= round.round %></h3>
            <span class="league-chip"><%= round.fixtures.length %> mechi</span>
        </header>
        <div class="league-surface-body">
            <div class="league-fixture-list">
                <% round.fixtures.forEach(fixture => { %>
                <%- include('../../shared/partials/fixture-row.ejs', { fixture }) %>
                <% }) %>
            </div>
        </div>
    </section>
    <% }) %>
</div>
