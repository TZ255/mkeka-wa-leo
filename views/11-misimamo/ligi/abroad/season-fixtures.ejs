<!DOCTYPE html>
<html lang="sw">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Ratiba na matokeo ya <%= partials.ligi %> - <%= partials.league_name %> <%= partials.season_long %>. Angalia mechi zote za msimu mzima kwa hatua zake na tarehe zake.">
    <%- include('../../../0-global/favicon.ejs') %>
    <meta property="article:modified_time" content="<%= partials.updatedAt %>">
    <link rel="canonical" href="https://mkekawaleo.com<%= partials.canonical_path %>">
    <title>Ratiba na Matokeo ya <%= partials.ligi %> <%= partials.season_long %></title>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../0-global/google.ejs'); %>
    <%- include('../../../0-global/fonts.ejs'); %>
    <%- include('../shared/partials/theme.ejs'); %>
</head>

<body>
    <%- include('../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell text-align-justify">
            <% const navLinks = [
                { href: `/standings/football/${partials.path}`, label: 'Msimamo', icon: 'fa-solid fa-table', active: false },
                { href: `/football/fixtures/${partials.path}`, label: 'Ratiba na Matokeo', icon: 'fa-regular fa-calendar-days', active: true }
            ]; %>
            <% if (partials.stats.scorer > 0) { navLinks.push({ href: `/football/top-scorers/${partials.path}`, label: 'Wafungaji Bora', icon: 'fa-solid fa-futbol', active: false }); } %>
            <% if (partials.stats.assist > 0) { navLinks.push({ href: `/football/top-assists/${partials.path}`, label: 'Watoa Assist Bora', icon: 'fa-solid fa-handshake-angle', active: false }); } %>

            <%- include('../shared/partials/hero.ejs', {
                partials,
                formattedUpdatedAt: new Date(partials.updatedAt).toLocaleString('sw-TZ', {
                    timeZone: 'Africa/Nairobi',
                    hour: '2-digit',
                    minute: '2-digit',
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                }),
                hero: {
                    title: `Ratiba na matokeo ya ${partials.ligi} ${partials.season_long}`,
                    copy: `Hapa ndipo unaona mechi zote za ${partials.league_name}, kuanzia hatua inayopigiwa macho sasa hadi ratiba ya msimu mzima pamoja na matokeo yaliyokwisha kuingia.`,
                    primary_pill: partials.season_long,
                    secondary_pill: partials.league_name,
                    stats: [
                        { value: partials.stats.fixtures || 0, label: 'Mechi' },
                        { value: partials.stats.rounds || 0, label: 'Hatua' },
                        { value: partials.stats.teams || 0, label: 'Timu' },
                        { value: partials.stats.scorer || 0, label: 'Wafungaji' },
                    ],
                }
            }) %>

            <%- include('../shared/partials/nav.ejs', { links: navLinks }) %>

            <%- include('./partials/fixtures.ejs'); %>

            <div class="vidokezo">
                <h2 class="league-block-title">Angalia pia <%= partials.league_name %> <%= partials.season_short %></h2>
                <ul class="list-group list-group-flush fw-bold">
                    <li class="list-group-item">
                        <a href="/standings/football/<%= partials.path %>">
                            Msimamo wa <%= partials.league_name %> <%= partials.season_short %>
                        </a>
                    </li>
                    <% if (partials.stats.scorer > 0) { %>
                    <li class="list-group-item">
                        <a href="/football/top-scorers/<%= partials.path %>">
                            Wafungaji bora wa <%= partials.league_name %> <%= partials.season_short %>
                        </a>
                    </li>
                    <% } %>
                    <% if (partials.stats.assist > 0) { %>
                    <li class="list-group-item">
                        <a href="/football/top-assists/<%= partials.path %>">
                            Watoa assist bora wa <%= partials.league_name %> <%= partials.season_short %>
                        </a>
                    </li>
                    <% } %>
                </ul>
            </div>

            <% if (typeof standing.standing[0] === 'object' && standing.standing[0] !== null && !Array.isArray(standing.standing[0])) { %>
            <%- include('./partials/teams-ratiba.ejs') %>
            <% } %>
            <%- include('../../../0-global/somapia.ejs'); %>
        </section>
        <%- include('../../../0-global/right.ejs'); %>
    </main>

    <%- include('../../../0-global/footer.ejs'); %>
    <%- include('../../../0-global/modal-leon.ejs'); %>
    <%- include('../../../0-global/script.ejs'); %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
