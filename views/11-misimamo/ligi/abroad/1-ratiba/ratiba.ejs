<!DOCTYPE html>
<html lang="sw">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Angalia ratiba ya mechi za <%= partials.team_info.team.name %> <%= partials.ligi %> pamoja na matokeo ya msimu mzima wa <%= partials.season_long %>">
    <meta property="article:modified_time" content="<%= partials.team_info.update %>">
    <link rel="canonical" href="https://mkekawaleo.com<%= partials.canonical_path %>">
    <%- include('../../../../0-global/favicon.ejs') %>
    <title>Ratiba na Matokeo ya Mechi za <%= partials.team_info.team.name %> <%= partials.season_long %></title>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../../0-global/google.ejs'); %>
    <%- include('../../../../0-global/fonts.ejs'); %>
    <%- include('../../shared/partials/theme.ejs'); %>
</head>

<body>
    <%- include('../../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell">
            <% const teamNavLinks = [
                { href: `/standings/football/${partials.path}`, label: 'Msimamo', icon: 'fa-solid fa-table', active: false },
                { href: `/football/fixtures/${partials.path}`, label: 'Ratiba ya ligi', icon: 'fa-regular fa-calendar-days', active: false },
                { href: `/football/fixtures/${partials.path}/${partials.team_id}`, label: partials.team_info.team.name, icon: 'fa-solid fa-shield-halved', active: true }
            ]; %>

            <%- include('../../shared/partials/hero.ejs', {
                partials,
                formattedUpdatedAt: new Date(partials.updatedAt).toLocaleString('sw-TZ', {
                    timeZone: 'Africa/Nairobi',
                    hour: '2-digit',
                    minute: '2-digit',
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                }),
                hero: {
                    title: `Ratiba na Matokeo ya Mechi za ${partials.team_info.team.name}`,
                    copy: `Fuatilia kila mechi ya ${partials.team_info.team.name} ndani ya ${partials.ligi} ${partials.season_long}, ukiona mwendo wake kwenye msimamo, idadi ya pointi, na ratiba yote ya msimu.`,
                    image_url: partials.team_info.team.logo,
                    image_alt: partials.team_info.team.name,
                    primary_pill: partials.season_long,
                    secondary_pill: partials.ligi,
                    stats: [
                        { value: partials.team_info.rank, label: 'Nafasi' },
                        { value: partials.team_info.points, label: 'Pointi' },
                        { value: partials.team_info.all.played, label: 'Mechi' },
                        { value: partials.team_info.goalsDiff, label: 'Goal diff' },
                    ],
                }
            }) %>

            <%- include('../../shared/partials/nav.ejs', { links: teamNavLinks }) %>

            <div class="table-section">
                <div class="utangulizi p text-align-justify">
                    <p>
                        <%= partials.team_info.team.name %> ni timu inayoshiriki <%= partials.ligi %> <%= partials.season_long %> ikiwa inashikilia nafasi ya
                        <%= partials.team_info.rank %> katika <a href="/standings/football/<%= partials.path %>" class="link-dark">Msimamo
                            wa <%= partials.ligi %> <%= partials.season_long %></a> na ikiwa na jumla ya <strong>points <%= partials.team_info.points %></strong>. Hadi sasa imecheza jumla
                        ya mechi
                        <%= partials.team_info.all.played %>, mechi <%= partials.team_info.home.played %> zikiwa za
                        nyumbani na <%= partials.team_info.away.played %> za ugenini.
                    </p>
                    <p>
                        <%= partials.team_info.team.name %> imeshinda mechi <%= partials.team_info.all.win %>, droo
                        <%= partials.team_info.all.draw %> na kufungwa mechi
                        <%= partials.team_info.all.lose %>. Amefunga mabao
                        <%= partials.team_info.all.goals.for %> na kufungwa <%= partials.team_info.all.goals.against %>
                        hivyo kuifanya kuwa na tofauti ya mabao <%= partials.team_info.goalsDiff %>
                    </p>
                </div>
            </div>
            <div class="table-section" itemscope itemtype="https://schema.org/Table">
                <div class="league-section-head">
                    <h2 class="league-subsection-title" itemprop="about">Msimamo wa <%= partials.team_info.team.name %> katika <%= partials.ligi %></h2>
                    <span class="league-chip">Nafasi ya <%= partials.team_info.rank %></span>
                </div>
                <div class="league-table-wrap">
                    <table class="league-table">
                        <colgroup>
                            <col style="width: 56px;">
                            <col class="team-col">
                            <col span="6" style="width: 9%;">
                        </colgroup>
                        <thead>
                            <tr>
                                <th class="rank-cell text-center">#</th>
                                <th class="team-cell">Timu</th>
                                <th class="stat-cell text-center">MP</th>
                                <th class="stat-cell text-center">W</th>
                                <th class="stat-cell text-center">D</th>
                                <th class="stat-cell text-center">L</th>
                                <th class="stat-cell text-center">GD</th>
                                <th class="stat-cell text-center">Pts</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="rank-cell rank-badge-cell">
                                    <span class="league-rank-wrap">
                                        <span class="league-rank-marker"></span>
                                        <span class="league-rank-number"><%= partials.team_info.rank %></span>
                                    </span>
                                </td>
                                <td class="team-cell">
                                    <div class="league-team-cell">
                                        <img src="<%= partials.team_info.team.logo %>" alt="<%= partials.team_info.team.name %>" loading="lazy">
                                        <span><%= partials.team_info.team.name %></span>
                                    </div>
                                </td>
                                <td class="stat-cell text-center"><%= partials.team_info.all.played %></td>
                                <td class="stat-cell text-center"><%= partials.team_info.all.win %></td>
                                <td class="stat-cell text-center"><%= partials.team_info.all.draw %></td>
                                <td class="stat-cell text-center"><%= partials.team_info.all.lose %></td>
                                <td class="stat-cell text-center"><%= partials.team_info.goalsDiff %></td>
                                <td class="stat-cell text-center league-highlight"><%= partials.team_info.points %></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="league-surface" itemscope itemtype="https://schema.org/Table">
                <div class="league-surface-head">
                    <h2 class="league-subsection-title" itemprop="about">Mechi za <%= partials.team_info.team.name %> kwa Msimu wa <%= partials.season_long %></h2>
                    <span class="league-chip">mechi <%= ratiba.length %></span>
                </div>
                <div class="league-surface-body">
                <div class="league-fixture-list">
                    <% ratiba.forEach(fixture => { %>
                    <%- include('../../shared/partials/fixture-row.ejs', { fixture }) %>
                    <% }) %>
                </div>
                </div>
            </div>
                <%- include('./partials/faq.ejs'); %>
                <%- include('../../../../0-global/somapia.ejs'); %>
        </section>
    </main>

    <%- include('../../../../0-global/footer.ejs'); %>
    <%- include('../../../../0-global/script.ejs'); %>
    <%- include('../../../../0-global/modal-leon.ejs'); %>

    <!-- bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
