<!DOCTYPE html>
<html lang="sw">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description"
        content="Angalia orodha ya wachezaji wanaongoza kwa asisti <%= partials.league_name %> - <%= partials.ligi %> kwa msimu wa <%= partials.season_long %>. Hawa hapa vinara wa Assist <%= partials.league_name %>.">
    <meta property="article:modified_time" content="<%= partials.updatedAt %>">
    <link rel="canonical" href="https://mkekawaleo.com<%= partials.canonical_path %>">
    <%- include('../../../../0-global/favicon.ejs') %>
    <title>Watoa Assist Bora <%= partials.league_name %> <%= partials.season_long %> - Vinara wa Assist
        <%= partials.ligi %></title>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../../../../0-global/google.ejs'); %>
    <%- include('../../../../0-global/fonts.ejs'); %>
    <%- include('../../shared/partials/theme.ejs'); %>
</head>

<body>
    <%- include('../../../../0-global/header.ejs'); %>
    <main>
        <section class="left league-shell text-align-justify">
            <% const navLinks = [
                { href: `/standings/football/${partials.path}`, label: 'Msimamo', icon: 'fa-solid fa-table', active: false },
                { href: `/football/fixtures/${partials.path}`, label: 'Ratiba na Matokeo', icon: 'fa-regular fa-calendar-days', active: false }
            ]; %>
            <% if (partials.stats.scorer > 0) { navLinks.push({ href: `/football/top-scorers/${partials.path}`, label: 'Wafungaji Bora', icon: 'fa-solid fa-futbol', active: false }); } %>
            <% navLinks.push({ href: `/football/top-assists/${partials.path}`, label: 'Watoa Assist Bora', icon: 'fa-solid fa-handshake-angle', active: true }); %>

            <%- include('../../shared/partials/hero.ejs', {
                partials,
                formattedUpdatedAt: new Date(partials.updatedAt).toLocaleString('sw-TZ', {
                    timeZone: 'Africa/Nairobi',
                    hour: '2-digit',
                    minute: '2-digit',
                    weekday: 'long',
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                }),
                hero: {
                    title: `Watoa Assist Bora wa ${partials.country} ${partials.league_name} ${partials.season_long}`,
                    copy: `Hapa unaona viungo na washambuliaji wanaotengeneza nafasi nyingi zaidi za magoli katika ${partials.ligi}, pamoja na ushindani wa kileleni wa orodha ya assists.`,
                    primary_pill: partials.season_long,
                    secondary_pill: partials.league_name,
                    stats: [
                        { value: partials.stats.assist || 0, label: 'Wachezaji' },
                        { value: partials.stats.scorer || 0, label: 'Wafungaji' },
                        { value: partials.stats.teams || 0, label: 'Timu' },
                        { value: partials.stats.fixtures || 0, label: 'Mechi' },
                    ],
                }
            }) %>

            <%- include('../../shared/partials/nav.ejs', { links: navLinks }) %>

            <% if (top_assists?.length > 1) { %>
            <div class="league-grid-two">
                <article class="league-highlight-card">
                    <h2 class="h5">Kinara wa sasa</h2>
                    <p class="mb-1"><strong><%= top_assists[0].player.name %></strong></p>
                    <p class="mb-0"><%= top_assists[0].statistics[0].team.name %> anaongoza akiwa na <strong><%= top_assists[0].statistics[0].goals.assists %></strong> assists.</p>
                </article>
                <article class="league-highlight-card">
                    <h2 class="h5">Anayemfukuzia</h2>
                    <p class="mb-1"><strong><%= top_assists[1].player.name %></strong></p>
                    <p class="mb-0"><%= top_assists[1].statistics[0].team.name %> yupo karibu kileleni akiwa na <strong><%= top_assists[1].statistics[0].goals.assists %></strong> assists.</p>
                </article>
            </div>
            <% } %>

            <section class="league-surface league-surface--table" itemscope itemtype="https://schema.org/Table">
                <header class="league-surface-head">
                    <div class="league-title-stack">
                        <span class="league-overline">Watoa Assist Bora</span>
                        <h2 class="league-section-title">Orodha ya Watoa Assist Bora wa <%= partials.league_name %></h2>
                        <p class="league-section-copy">Fuatilia wabunifu wa mwisho wa mashambulizi, timu wanazotokea na idadi ya pasi za mwisho zinazogeuka kuwa mabao.</p>
                    </div>
                    <span class="league-chip"><%= top_assists.length %> wachezaji</span>
                </header>
                <meta itemprop="about" content="Wachezaji Wanaongoza kwa Asisti <%= partials.league_name %> Msimu wa <%= partials.season_long %>">
                <div class="league-table-wrap">
                    <table class="league-table league-player-table">
                        <colgroup>
                            <col class="rank-col">
                            <col class="player-col">
                            <col class="team-col">
                            <col class="stat-col">
                            <col class="meta-col">
                        </colgroup>
                        <thead>
                            <tr>
                                <th class="rank-cell text-center">#</th>
                                <th class="team-cell">Mchezaji</th>
                                <th>Timu</th>
                                <th class="text-center">Asisti</th>
                                <th class="text-center">Michezo</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% top_assists.forEach((player, index) => { %>
                            <tr>
                                <td class="rank-cell rank-badge-cell">
                                    <span class="league-rank-wrap">
                                        <span class="league-rank-marker"></span>
                                        <span class="league-rank-number"><%= index+1 %></span>
                                    </span>
                                </td>
                                <td class="team-cell">
                                    <div class="league-player-cell">
                                        <img src="<%= player.player.photo %>" alt="<%= player.player.name %>" class="league-player-photo" loading="lazy">
                                        <div>
                                            <strong><%= player.player.name %></strong>
                                            <span class="league-player-sub"><%= player.player.age ? `${player.player.age} yrs` : 'Mchezaji wa ubunifu' %></span>
                                        </div>
                                    </div>
                                </td>
                                <td><%= player.statistics[0].team.name %></td>
                                <td class="text-center league-highlight"><%= player.statistics[0].goals.assists %></td>
                                <td class="text-center"><%= player.statistics[0].games.appearences %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="league-legend">
                    <% if (partials?.stats?.scorer > 0) { %>
                    <span><a href="/football/top-scorers/<%= partials.path %>">Wafungaji Bora wa <%= partials.league_name %> <%= partials.season_short %></a></span>
                    <% } %>
                    <span><a href="/standings/football/<%= partials.path %>">Msimamo wa <%= partials.ligi %> <%= partials.season_short %></a></span>
                    <span><a href="/football/fixtures/<%= partials.path %>">Ratiba na matokeo ya <%= partials.ligi %> <%= partials.season_short %></a></span>
                </div>
            </section>
            <%- include('../../../../0-global/somapia.ejs'); %>
        </section>
    </main>

    <%- include('../../../../0-global/footer.ejs'); %>
    <%- include('../../../../0-global/script.ejs'); %>
    <%- include('../../../../0-global/modal-leon.ejs'); %>

    <!-- bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
