<section id="supa-over15-section" class="mega-card card border-0 shadow-sm" itemscope>
  <!-- Navigation Header -->
  <div class="btn-group" role="group" aria-label="Mikeka ya Jana, Leo na Kesho">
    <!-- DISABLED: Jana button – uncomment to re-enable
    <button type="button"
       hx-get="/api/tips/over15?siku=jana" hx-target="#supa-over15-section" hx-swap="outerHTML"
       hx-on::before-request="__tipsLoading('supa-over15-section')"
       class="btn <%%= trh.siku === 'jana' ? 'btn-dark text-light' : 'btn-light text-secondary' %>" title="Mikeka ya Jana" style="border-top-left-radius: 16px; border-bottom-left-radius: 0;">
      Jana
    </button>
    -->
    <a href="/#supa-over15"
       hx-get="/api/tips/over15?siku=leo" hx-target="#supa-over15-section" hx-swap="outerHTML"
       hx-on::before-request="__tipsLoading('supa-over15-section')"
       class="btn <%= trh.siku === 'leo' ? 'btn-dark text-light' : 'btn-light text-secondary' %>" title="Mkeka wa Leo" style="border-bottom-left-radius: 0;">
      Leo
    </a>
    <a href="/mkeka/kesho#supa-over15"
       hx-get="/api/tips/over15?siku=kesho" hx-target="#supa-over15-section" hx-swap="outerHTML"
       hx-on::before-request="__tipsLoading('supa-over15-section')"
       class="btn <%= trh.siku === 'kesho' ? 'btn-dark text-light' : 'btn-light text-secondary' %>" title="Mikeka ya Kesho" style="border-top-right-radius: 16px; border-bottom-right-radius: 0;">
      Kesho
    </a>
  </div>

  <!-- Title header -->
  <div class="mega-card__header border-top" id="supa-over15">
    <div class="container-fluid py-3 py-md-4 px-3 px-md-4">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <h2 class="mega-card__title m-0 fw-bold fs-3">
          <span class="bullet" aria-hidden="true"></span>
          Over 1.5: Supa za Kesho
        </h2>
        <div class="date-wrap d-flex align-items-center gap-2">
          <span class="day-chip"><i class="fa-regular fa-calendar me-1"></i>
            <%= jumasiku.kesho %>
          </span>
          <span class="vr d-none d-sm-inline"></span>
          <span class="date-badge">
            <%= trh.kesho %>
          </span>
        </div>
      </div>
    </div>
  </div>

  <% if (super_over15?.length> 0) { %>
  <div class="mega-card__body px-2 px-md-3 py-2 py-md-3">
    <div class="prediction-list">
      <% super_over15.forEach(el=> { %>
      <!-- variables -->
      <% const _parts=(el.match || '' ).split(' - '); 
            const _home = _parts[0] || ''; 
            const _away = _parts[1] || ''; 
            %>
      <article class="prediction" itemscope itemtype="https://schema.org/CreativeWork">
        <div class="prediction__grid">
          <div class="prediction__meta">
            <div class="time"><i class="fa-regular fa-clock me-1"></i><%= el.time %></div>
            <div class="league mt-1" data-fixture_id="<%= el?.fixture_id %>">
              <span class="league-tag"><%= el.league %></span>
            </div>
          </div>
          <div class="prediction__match">
            <div class="teams">
              <div class="team">
                <img src="<%= el.logo.home %>" alt="" loading="lazy" width="20" aria-hidden="true">
                <span class="name"><%= _home %></span>
              </div>
              <div class="team">
                <img src="<%= el.logo.away %>" alt="" loading="lazy" width="20" aria-hidden="true">
                <span class="name"><%= _away %></span>
              </div>
            </div>
            <div class="bet mt-2 mt-md-1"><span class="bet-tag"><%= el.bet %> <span class="bet-tag__odds"><%= Number(el.odds).toFixed(2) %></span></span></div>
          </div>
          <% const accuracy = Number(el?.accuracy || 0); %>
          <% const hasAccuracy = accuracy > 0; %>
          <% const normalizedAccuracy = Math.max(0, Math.min(100, accuracy)); %>
          <% const displayAccuracy = Math.round(normalizedAccuracy); %>
          <div class="prediction__progress">
            <div class="gold-bar" role="progressbar" aria-valuenow="<%= hasAccuracy ? displayAccuracy : el.odds %>" aria-valuemin="0" aria-valuemax="100">
              <div class="gold-bar__track">
                <div class="gold-bar__fill" style="width:<%= hasAccuracy ? normalizedAccuracy : Math.min(Number(el.odds) * 10, 100) %>%"></div>
              </div>
              <span class="gold-bar__value">
                <% if (hasAccuracy) { %><%= displayAccuracy %>%<% } else { %><%= String(el.odds).padEnd(4, '0') %><% } %>
              </span>
            </div>
            <%- include('../../0-global/result-badge.ejs') %>
          </div>
        </div>

        <!-- SEO CreativeWork -->
        <meta itemprop="headline" content="<%= _home %> vs <%= _away %> prediction - <%= trh.kesho %>">
        <meta itemprop="about" content="Utabiri wa <%= trh.siku %> mechi ya <%= _home %> vs <%= _away %>, <%= el.league %>">
        <meta itemprop="abstract" content="Mechi hii ya <%= _home %> vs <%= _away %> utabiri wetu wa mwisho ni - <%= el.bet %>">
        <meta itemprop="datePublished" content="<%= trh.created %>">
        <meta itemprop="dateModified" content="<%= trh.created %>">
        <meta itemprop="author" content="Mkeka wa Leo">
        <meta itemprop="publisher" content="Mkeka wa Leo">
        <meta itemprop="keywords" content="utabiri wa mechi za <%= trh.siku %>, utabiri wa <%= el.league %>, <%= _home %> vs <%= _away %> prediction">
        <meta itemprop="mainEntityOfPage" content="https://mkekawaleo.com/">
      </article>
      <% }) %>
    </div>
  </div>
  <% } %>

  <!-- If no Tips -->
  <% if (super_over15.length==0) { %>
  <div class="alert alert-warning mx-1" role="alert">
    Bado hakuna tips za Supa Over 1.5 kwa siku ya kesho, tafadhali tembelea tena baadae au endelea
    kufuatilia <a href="/mkeka" class="text-success" title="Mikeka ya Bure">mikeka yetu mingine ya
      bure hapa.</a>
  </div>
  <br>
  <% } %>

  <div class="mega-card__summary border-top">
    <div class="container-fluid py-3 py-md-4 px-3 px-md-4">
      <div class="row g-3 align-items-stretch metrics">
        <div class="col-12 col-md-4">
          <div class="stat d-flex align-items-center gap-3 stat--bookie">
            <div class="stat__icon"><i class="fa-solid fa-building-columns"></i></div>
            <div class="stat__body">
              <div class="label">Kampuni</div>
              <div class="value"><span class="badge text-bg-dark px-3 py-2">BETWAY</span></div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4">
          <div class="stat d-flex align-items-center gap-3 stat--odds">
            <div class="stat__icon"><i class="fa-solid fa-chart-line"></i></div>
            <div class="stat__body">
              <div class="label">Total Odds</div>
              <div class="value fw-bold fs-5">
                <%= Number(supa15_odds) > 9999 ? "9999+" : supa15_odds %>
              </div>
            </div>
          </div>
        </div>
        <div class="col-6 col-md-4">
          <div class="stat d-flex align-items-center gap-3 stat--bonus">
            <div class="stat__icon"><i class="fa-solid fa-gift"></i></div>
            <div class="stat__body">
              <div class="label">Bonus</div>
              <div class="value fw-semibold">400%</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  if (typeof __tipsLoading === 'undefined') {
    window.__tipsLoading = function (id) {
      var s = document.getElementById(id);
      if (!s) return;
      var h = s.querySelector('.mega-card__header');
      if (h) h.innerHTML = '<div class="d-flex justify-content-center py-5"><div class="spinner-border text-success" role="status"><span class="visually-hidden">Inapakia...</span></div></div>';
      s.querySelectorAll('.mega-card__body, .alert, .mega-card__summary').forEach(function (el) { el.style.display = 'none'; });
    }
  }
</script>
