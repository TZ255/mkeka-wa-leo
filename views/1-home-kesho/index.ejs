<!DOCTYPE html>
<html lang="sw">

<head>
    <%- include("../0-global/seo/head.ejs"); %>

    <!-- htmx -->
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.7/dist/htmx.min.js"
        integrity="sha384-ZBXiYtYQ6hJ2Y0ZNoYuI+Nq5MqWBr+chMrS/RkXpNzQCApHEhOt2aY8EJgqwHLkJ"
        crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/v7-mega.css">
    <%- include('./partials/style.ejs'); %>
    <link rel="stylesheet" href="/css/v1-global.css">
    <%- include('../0-global/google.ejs'); %>
</head>

<body>
    <%- include('../0-global/header.ejs'); %>
    <main>
        <section class="left">
            <h1 class="h2" style="font-size: 16px;">Mikeka ya Kesho - <%= trh.kesho %></h1>
            <div class="introduction p">
                <p>
                    Karibu mahali ambapo ushindi wako unathaminika!
                    Pata utabiri wa mechi za kesho na uchambuzi bora wa mikeka ya kubeti ili kuongeza nafasi zako za ushindi.
                </p>
                <p>
                    Tunatoa aina mbalimbali za bashiri, ikiwemo:
                </p>
                <ul>
                    <li><strong>1X2</strong> (Bashiri za ushindi wa moja kwa moja)</li>
                    <li>Bashiri za <strong>Over 1.5 Goals</strong></li>
                    <li>Bashiri za <strong>Over/Under 2.5 Goals</strong></li>
                    <li>Bashiri za <strong>Over/Under 3.5 Goals</strong></li>
                    <li>Bashiri za <strong>Both Teams To Score (BTTS)</strong></li>
                    <li>Bashiri za <strong>Correct Score</strong></li>
                    <li>Bashiri za <strong>Double Chance</strong></li>
                </ul>
                <p>
                    Mikeka yetu imeandaliwa kwa kutumia takwimu sahihi na uchambuzi wa kina wa mechi za mpira wa miguu,
                    ili kukuhakikishia nafasi kubwa zaidi ya ushindi kila siku. Jiunge nasi Kesho na ugeuze maarifa yako
                    ya
                    mpira kuwa mafanikio makubwa katika ulimwengu wa kubeti!
                </p>
            </div>
            <%- include('../0-global/banner.ejs'); %>
            <hr class="my-3 text-light">
            <%- include('./partials/mega.ejs'); %>
            <hr class="my-5 text-light">
            <%- include('../0-global/vip.ejs'); %>
            <hr class="style-eight">
            <%- include('./partials/supa-over15.ejs'); %>
            <%- include('../0-global/banner2.ejs'); %>
            <%- include('../0-global/banner3.ejs'); %>
            <hr class="my-5 text-light">
            <%- include('./partials/supa-dc.ejs'); %>
            <%- include('./partials/whatsapp.ejs'); %>
            <%- include('../0-global/somapia.ejs'); %>
            <%- include('./partials/maana.ejs'); %>
        </section>
        <%- include('../0-global/right.ejs'); %>
    </main>

    <%- include('../0-global/footer.ejs'); %>

    <%- include('./partials/script.ejs'); %>
    <%- include('../0-global/script.ejs'); %>
    <%- include('../0-global/modal.ejs'); %>

    <!-- bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>