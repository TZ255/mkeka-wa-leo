<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../0-global/fonts.ejs'); %>
    <%- include('../0-global/favicon.ejs'); %>
    <title><%= title %></title>
    <style>
        body { background: #0f1117; color: #e1e1e1; font-family: 'Segoe UI', sans-serif; }
        .container { max-width: 900px; }
        h1 { font-size: 1.4rem; font-weight: 700; }
        .badge-acc { font-size: .75rem; padding: 3px 8px; border-radius: 4px; font-weight: 600; }
        .acc-high { background: #198754; color: #fff; }
        .acc-mid { background: #fd7e14; color: #fff; }
        .acc-low { background: #dc3545; color: #fff; }
        .nav-pills .nav-link { color: #adb5bd; border-radius: 8px; font-size: .85rem; }
        .nav-pills .nav-link.active { background: #198754; color: #fff; }
        .tips-table { width: 100%; border-collapse: separate; border-spacing: 0 4px; }
        .tips-table th { font-size: .7rem; text-transform: uppercase; color: #6c757d; padding: 6px 10px; border: none; }
        .tips-table td { padding: 10px; background: #1a1d26; font-size: .85rem; }
        .tips-table tr td:first-child { border-radius: 8px 0 0 8px; }
        .tips-table tr td:last-child { border-radius: 0 8px 8px 0; }
        .team-names { line-height: 1.3; }
        .team-names small { color: #6c757d; font-size: .7rem; }
        .odds-val { font-weight: 600; color: #ffc107; }
        .tip-label { font-weight: 600; }
        .match-time { color: #6c757d; font-size: .75rem; white-space: nowrap; }
        .league-name { color: #6c757d; font-size: .72rem; }
        .empty-msg { text-align: center; padding: 40px; color: #6c757d; }
    </style>
</head>
<body>
    <%- include('../0-global/header.ejs'); %>

    <div class="container py-4">
        <h1 class="mb-3"><%= title %></h1>
        <p class="text-muted mb-3" style="font-size:.82rem"><%= date %> &middot; <%= tips.length %> matches</p>

        <ul class="nav nav-pills mb-3 gap-2">
            <li class="nav-item">
                <a class="nav-link <%= active === 'best' ? 'active' : '' %>" href="/odds-tips/best-picks">Best Picks</a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= active === 'over25' ? 'active' : '' %>" href="/odds-tips/over-2-5">Over 2.5</a>
            </li>
            <li class="nav-item">
                <a class="nav-link <%= active === 'btts' ? 'active' : '' %>" href="/odds-tips/btts">BTTS</a>
            </li>
        </ul>

        <% if (tips.length === 0) { %>
            <div class="empty-msg">No tips available for today yet.</div>
        <% } else { %>
            <table class="tips-table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Match</th>
                        <th>Tip</th>
                        <th>Odds</th>
                        <th>Acc</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (const tip of tips) { %>
                    <tr>
                        <td>
                            <div class="match-time"><%= tip.time %></div>
                        </td>
                        <td>
                            <div class="team-names">
                                <%= tip.home %> vs <%= tip.away %>
                                <br><small class="league-name"><%= tip.league %></small>
                            </div>
                        </td>
                        <td><span class="tip-label"><%= tip.label %></span></td>
                        <td><span class="odds-val"><%= tip.odds %></span></td>
                        <td>
                            <span class="badge-acc <%= tip.accuracy >= 60 ? 'acc-high' : tip.accuracy >= 40 ? 'acc-mid' : 'acc-low' %>">
                                <%= tip.accuracy %>%
                            </span>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        <% } %>
    </div>

    <%- include('../0-global/footer.ejs'); %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-T3BN4IUFKm2LPV2ZHXU14uMa11a6ywlhz+S/8fy0fBr4d4bRoMhy3GwR54QLRJZ"
        crossorigin="anonymous"></script>
</body>
</html>
