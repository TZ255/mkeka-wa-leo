<!DOCTYPE html>
<html lang="sw">

<head>
  <%- include("../0-global/seo/head.ejs"); %>
  <link rel="stylesheet" href="/css/v7-mega.css">
  <link rel="stylesheet" href="/css/v1-global.css">
  <%- include('../0-global/google.ejs'); %>
</head>

<body>
  <%- include('../0-global/header.ejs'); %>
  <main>
    <section class="left">
      <h1 class="h2" style="font-size: 16px;">Mkeka wa Double Chance - <%= SEO.trh.day %>, <%= SEO.trh.date %></h1>
      <div class="introduction p">
        <p>
          Karibu mahali ambapo ushindi wako unathaminika!
          Pata utabiri wa Double Chance (DC) za uhakika kwa siku ya <strong><%= SEO.siku %></strong>. Kwa siku ya <%= SEO.siku.toLowerCase() %> tarehe <%= SEO.trh.date %> tuna jumla ya mechi <strong><%= mikeka.length %></strong> za Double Chance (DC) zilizochambuliwa kwa umakini wa hali ya juu, kuhakikisha unakuwa katika nafasi bora zaidi ya kushinda.
        </p>
        <p>
          Tunatoa aina zote za bashiri za Double Chance (DC), ikiwemo:
        </p>
        <ul style="list-style: circle;">
          <li><strong>1X:</strong> Timu ya Nyumbani kushinda au mechi kumalizika kwa sare</li>
          <li><strong>X2:</strong> Timu ya Ugenini kushinda au mechi kumalizika kwa sare</li>
          <li><strong>12:</strong> Timu ya Nyumbani au Ugenini kushinda</li>
        </ul>
      </div>
      <%- include('../0-global/banner.ejs'); %>
      <hr class="my-3 text-light">
      <%- include('./partials/mega.ejs'); %>
      <%- include('../0-global/weekday-nav.ejs'); %>
      <hr class="my-5 text-light">
      <%- include('../0-global/vip.ejs'); %>
      <%- include('../0-global/banner2.ejs'); %>
      <%- include('./partials/maana.ejs'); %>
      <%- include('../0-global/banner3.ejs'); %>
      <%- include('../0-global/somapia.ejs'); %>
    </section>
    <%- include('../0-global/right.ejs'); %>
  </main>

  <%- include('../0-global/footer.ejs'); %>

  <%- include('./partials/script.ejs'); %>
  <%- include('../0-global/script.ejs'); %>
  <%- include('../0-global/vip-modal.ejs'); %>

  <!-- bootstrap -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>
