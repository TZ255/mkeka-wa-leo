<!DOCTYPE html>
<html lang="sw">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%- include('../0-global/fonts.ejs'); %>
    <meta name="google-site-verification" content="bEyk3C5a5dMvt5kOo3RiLqwWiHoUjbslRYXKu-johrc" />
    <meta name="description" content="Mikeka ya bure na mega odds za <%= partials.siku %>. Shinda beti zako kwa tabiri zote za mechi za siku ya <%= partials.siku %> na mikeka yetu inayojumuisha 1X2, Over 1.5, Over 2.5 na Both Teams to Score">
    <title>Mkeka wa <%= partials.siku %> | <%= partials.trh.mega %></title>
    <link rel="canonical" href="https://mkekawaleo.com<%= partials.canonicalPath %>">
    <%- include('./partials/style.ejs'); %>
    <link rel="stylesheet" href="/css/v1-global.css">
    <link rel="stylesheet" href="/css/v5-mega.css">
    <%- include('../0-global/google.ejs'); %>
    <%- include('../0-global/favicon.ejs') %>
</head>

<body>
    <%- include('../0-global/header.ejs'); %>
    <main>
        <section class="left">
            <h1 class="h2" style="font-size: 16px;">Mikeka ya <%= partials.siku %>, <%= partials.trh.mega %></h1>
            <div class="intro p">
                <p>
                    Karibu jamvini kwa mikeka yetu ya bure ya <%= partials.siku %>. Hapa tumekuwekea utabiri wa mechi za leo zote. Tabiri zetu zimechambuliwa kwa umakini mkubwa ili kukuhakikishia wewe mdau wetu nafasi nzuri ya ushindi.
                </p>
                <p>
                    
                    Kwa siku ya <%= partials.siku %>, <strong><%= partials.trh.mega %></strong>, tumeandaa jumla ya mechi <strong><%= mikeka.length %></strong> zenye jumla ya odds <strong><%= Number(megaOdds) > 9999 ? "9,999+" : Number(megaOdds).toLocaleString("sw-TZ", {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></strong>
                </p>
            </div>
            <br><br>
            <%- include('../0-global/banner.ejs'); %>
            <br>
            <section class="megaodds" itemscope>
                <%- include('./partials/mega.ejs'); %>
            </section> <br>
            <% const allDays = ['jumatatu','jumanne','jumatano','alhamisi','ijumaa','jumamosi','jumapili']; %>
            <nav class="card border-0 shadow-sm overflow-hidden mb-4" style="background:#0f1420; border-radius:16px; border:1px solid rgba(255,255,255,.08);">
                <div class="d-flex flex-wrap justify-content-center gap-2 p-3">
                    <% allDays.forEach(day => {
                        const label = day.charAt(0).toUpperCase() + day.slice(1);
                        const isActive = day === partials.siku.toLowerCase();
                    %>
                    <a href="/mkeka/<%= day %>"
                       class="btn btn-sm rounded-pill fw-semibold px-3 <%= isActive ? 'text-dark' : 'text-light' %>"
                       style="<%= isActive
                         ? 'background:linear-gradient(180deg,#2bd576,#14b862); box-shadow:0 4px 12px rgba(20,184,98,.35);'
                         : 'background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08);' %>">
                        <%= label %>
                    </a>
                    <% }) %>
                </div>
            </nav>
            <hr>
            <%- include('../0-global/banner2.ejs'); %>
            <%- include('../0-global/somapia.ejs'); %>
        </section>
        <%- include('../0-global/right.ejs'); %>
    </main>

    <%- include('../0-global/footer.ejs'); %>

    <%- include('./partials/script.ejs'); %>
    <%- include('../0-global/script.ejs'); %>
    <%- include('../0-global/modal.ejs'); %>

    <!-- bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>

</html>